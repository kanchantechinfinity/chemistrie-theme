{%- assign stars = '★★★★★' -%}
<section class="page-section page-section--paper cnotes">
  <div class="page-section__inner">
    <div class="page-section__head">
      <span class="eyebrow">— From real formulas —</span>
      <h2 class="display-h">Verified<br/><em>skin notes.</em></h2>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="cnotes__grid">
        {%- for block in section.blocks -%}
          <figure class="cnote" {{ block.shopify_attributes }}>
            <div class="cnote__stars" aria-label="5 out of 5 stars">{{ stars }}</div>
            <blockquote class="cnote__quote">{{ block.settings.quote }}</blockquote>
            <figcaption class="cnote__author">{{ block.settings.author }}</figcaption>
          </figure>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.cnotes__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(16px, 1.8vw, 24px); }
.cnote {
  display: flex; flex-direction: column; gap: 14px; margin: 0;
  background: var(--c-cream); border: 1px solid var(--c-line-soft); border-radius: 14px;
  padding: 26px 24px 28px;
}
.cnote__stars { color: var(--c-tan); font-size: 15px; letter-spacing: .12em; }
.cnote__quote { margin: 0; font-family: var(--ff-display); font-size: 18px; line-height: 1.45; color: var(--c-forest); }
.cnote__author { font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--c-ink-mute); margin-top: auto; }

@media (max-width: 1100px) { .cnotes__grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .cnotes__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

