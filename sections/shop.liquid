<!-- ───── Featured products ───── -->
<section class="shop" id="shop" data-screen-label="04 Shop">
  <div class="shop__head">
    <span class="eyebrow">— The Collection —</span>
    <h2 class="display-h">{{ section.settings.heading }}</h2>
    <p class="shop__lede">{{ section.settings.lede }}</p>
  </div>

  <div class="shop__rail-wrap">
    <div class="shop__rail">
      <div class="shop__grid">
    {% if section.settings.collection == blank %}
    <!-- product cards generated by JS for variety, but kept declarative -->
    <article class="product" data-color="forest">
      <button class="wish-btn" type="button" data-wishlist-toggle data-handle="renewal-serum" data-title="Renewal Serum" data-price="$148" data-image="" data-url="#" aria-label="Save to wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg></button>
      <div class="product__media">
        <span class="product__tag">No. 01 · Bestseller</span>
        <svg class="product__bottle" viewBox="0 0 140 220" aria-hidden="true">
          <defs>
            <linearGradient id="g1" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#2a5a44"/><stop offset="1" stop-color="#1a3a2d"/></linearGradient>
          </defs>
          <rect x="56" y="6" width="28" height="26" rx="2" fill="#c8aa7a"/>
          <rect x="40" y="32" width="60" height="180" rx="6" fill="url(#g1)"/>
          <rect x="50" y="100" width="40" height="68" fill="#f9f4ed"/>
          <text x="70" y="124" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="10" fill="#1a3a2d">No. 01</text>
          <line x1="58" y1="130" x2="82" y2="130" stroke="#c8aa7a" stroke-width="0.5"/>
          <text x="70" y="146" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">RENEWAL</text>
          <text x="70" y="158" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">SERUM</text>
        </svg>
      </div>
      <div class="product__meta">
        <div class="product__meta-top">
          <div>
            <h3>Renewal Serum</h3>
            <p>Retinaldehyde 0.05% · Niacinamide 4%</p>
          </div>
          <span class="product__price">$148</span>
        </div>
        <button class="product__cta" type="button">Add to Cart</button>
      </div>
    </article>

    <article class="product" data-color="sage">
      <button class="wish-btn" type="button" data-wishlist-toggle data-handle="vitamin-c-elixir" data-title="Vitamin C Elixir" data-price="$132" data-image="" data-url="#" aria-label="Save to wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg></button>
      <div class="product__media">
        <span class="product__tag">No. 02</span>
        <svg class="product__bottle" viewBox="0 0 140 220" aria-hidden="true">
          <defs>
            <linearGradient id="g2" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#8aab98"/><stop offset="1" stop-color="#6c8f7b"/></linearGradient>
          </defs>
          <rect x="60" y="4" width="20" height="34" rx="2" fill="#1a3a2d"/>
          <ellipse cx="70" cy="38" rx="14" ry="4" fill="#c8aa7a"/>
          <path d="M44 50 Q44 42 60 42 H80 Q96 42 96 50 L102 210 Q102 214 96 214 H44 Q38 214 38 210 Z" fill="url(#g2)"/>
          <rect x="48" y="110" width="44" height="64" fill="#f9f4ed"/>
          <text x="70" y="132" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="10" fill="#1a3a2d">No. 02</text>
          <line x1="58" y1="138" x2="82" y2="138" stroke="#c8aa7a" stroke-width="0.5"/>
          <text x="70" y="154" text-anchor="middle" font-family="Cormorant Garamond" font-size="7" letter-spacing="1.5" fill="#1a3a2d">VITAMIN C</text>
          <text x="70" y="164" text-anchor="middle" font-family="Cormorant Garamond" font-size="7" letter-spacing="1.5" fill="#1a3a2d">ELIXIR</text>
        </svg>
      </div>
      <div class="product__meta">
        <div class="product__meta-top">
          <div>
            <h3>Vitamin C Elixir</h3>
            <p>L-Ascorbic 15% · Ferulic · Vitamin E</p>
          </div>
          <span class="product__price">$132</span>
        </div>
        <button class="product__cta" type="button">Add to Cart</button>
      </div>
    </article>

    <article class="product" data-color="tan">
      <button class="wish-btn" type="button" data-wishlist-toggle data-handle="golden-oil" data-title="Golden Oil" data-price="$96" data-image="" data-url="#" aria-label="Save to wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg></button>
      <div class="product__media">
        <span class="product__tag">No. 03</span>
        <svg class="product__bottle" viewBox="0 0 140 220" aria-hidden="true">
          <defs>
            <linearGradient id="g3" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#dec39a"/><stop offset="1" stop-color="#c8aa7a"/></linearGradient>
          </defs>
          <!-- dropper tip -->
          <rect x="66" y="2" width="8" height="18" rx="2" fill="#c8aa7a"/>
          <!-- dropper bulb -->
          <ellipse cx="70" cy="22" rx="14" ry="6" fill="#1a3a2d"/>
          <!-- neck -->
          <rect x="61" y="16" width="18" height="22" rx="2" fill="#1a3a2d"/>
          <!-- shoulder -->
          <path d="M50 38 Q50 34 70 34 Q90 34 90 38 L92 54 H48 Z" fill="url(#g3)"/>
          <!-- body -->
          <rect x="46" y="52" width="48" height="160" rx="4" fill="url(#g3)"/>
          <!-- label -->
          <rect x="54" y="112" width="32" height="68" fill="#f9f4ed"/>
          <text x="70" y="134" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="10" fill="#1a3a2d">No. 03</text>
          <line x1="60" y1="140" x2="80" y2="140" stroke="#1a3a2d" stroke-width="0.5"/>
          <text x="70" y="154" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">GOLDEN</text>
          <text x="70" y="164" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">OIL</text>
        </svg>
      </div>
      <div class="product__meta">
        <div class="product__meta-top">
          <div>
            <h3>Golden Oil</h3>
            <p>Squalane · Bakuchiol · Calendula</p>
          </div>
          <span class="product__price">$96</span>
        </div>
        <button class="product__cta" type="button">Add to Cart</button>
      </div>
    </article>

    <article class="product" data-color="cream">
      <button class="wish-btn" type="button" data-wishlist-toggle data-handle="velvet-cream" data-title="Velvet Cream" data-price="$118" data-image="" data-url="#" aria-label="Save to wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg></button>
      <div class="product__media">
        <span class="product__tag">No. 04</span>
        <svg class="product__bottle" viewBox="0 0 140 220" aria-hidden="true">
          <defs>
            <linearGradient id="g4" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#fefaf3"/><stop offset="1" stop-color="#ece1cd"/></linearGradient>
          </defs>
          <!-- pump nozzle -->
          <rect x="67" y="2" width="6" height="28" rx="2" fill="#c8aa7a"/>
          <!-- pump head -->
          <rect x="58" y="2" width="24" height="10" rx="3" fill="#1a3a2d"/>
          <!-- pump collar -->
          <ellipse cx="70" cy="34" rx="16" ry="5" fill="#1a3a2d" opacity=".7"/>
          <!-- shoulder taper -->
          <path d="M47 42 Q47 36 64 36 H76 Q93 36 93 42 L95 56 H45 Z" fill="url(#g4)"/>
          <!-- body -->
          <rect x="43" y="54" width="54" height="158" rx="5" fill="url(#g4)"/>
          <!-- label area -->
          <rect x="52" y="116" width="36" height="64" fill="#1a3a2d" opacity=".06"/>
          <text x="70" y="138" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="10" fill="#1a3a2d">No. 04</text>
          <line x1="60" y1="144" x2="80" y2="144" stroke="#c8aa7a" stroke-width="0.5"/>
          <text x="70" y="158" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">VELVET</text>
          <text x="70" y="168" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">CREAM</text>
        </svg>
      </div>
      <div class="product__meta">
        <div class="product__meta-top">
          <div>
            <h3>Velvet Cream</h3>
            <p>Ceramide complex · Peptide-5</p>
          </div>
          <span class="product__price">$118</span>
        </div>
        <button class="product__cta" type="button">Add to Cart</button>
      </div>
    </article>

    <article class="product" data-color="forest">
      <button class="wish-btn" type="button" data-wishlist-toggle data-handle="clarifying-tonic" data-title="Clarifying Tonic" data-price="$84" data-image="" data-url="#" aria-label="Save to wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg></button>
      <div class="product__media">
        <span class="product__tag">No. 05</span>
        <svg class="product__bottle" viewBox="0 0 140 220" aria-hidden="true">
          <defs>
            <linearGradient id="g5" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#2a5a44"/><stop offset="1" stop-color="#0e2118"/></linearGradient>
          </defs>
          <path d="M60 4 Q60 0 70 0 Q80 0 80 4 L82 24 H58 Z" fill="#c8aa7a"/>
          <path d="M48 24 Q48 18 70 18 Q92 18 92 24 L96 50 L98 210 Q98 214 92 214 H48 Q42 214 42 210 L44 50 Z" fill="url(#g5)"/>
          <rect x="50" y="110" width="40" height="64" fill="#f9f4ed"/>
          <text x="70" y="132" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="10" fill="#1a3a2d">No. 05</text>
          <line x1="58" y1="138" x2="82" y2="138" stroke="#c8aa7a" stroke-width="0.5"/>
          <text x="70" y="154" text-anchor="middle" font-family="Cormorant Garamond" font-size="7" letter-spacing="1.5" fill="#1a3a2d">CLARIFYING</text>
          <text x="70" y="164" text-anchor="middle" font-family="Cormorant Garamond" font-size="7" letter-spacing="1.5" fill="#1a3a2d">TONIC</text>
        </svg>
      </div>
      <div class="product__meta">
        <div class="product__meta-top">
          <div>
            <h3>Clarifying Tonic</h3>
            <p>Mandelic 8% · Centella · Allantoin</p>
          </div>
          <span class="product__price">$84</span>
        </div>
        <button class="product__cta" type="button">Add to Cart</button>
      </div>
    </article>

    <article class="product" data-color="sage">
      <button class="wish-btn" type="button" data-wishlist-toggle data-handle="eye-concentrate" data-title="Eye Concentrate" data-price="$92" data-image="" data-url="#" aria-label="Save to wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg></button>
      <div class="product__media">
        <span class="product__tag">No. 06 · New</span>
        <svg class="product__bottle" viewBox="0 0 140 220" aria-hidden="true">
          <defs>
            <linearGradient id="g6" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#8aab98"/><stop offset="1" stop-color="#56745f"/></linearGradient>
          </defs>
          <rect x="58" y="4" width="24" height="28" rx="2" fill="#c8aa7a"/>
          <circle cx="70" cy="42" r="6" fill="#1a3a2d"/>
          <rect x="38" y="48" width="64" height="166" rx="32" fill="url(#g6)"/>
          <rect x="48" y="120" width="44" height="64" fill="#f9f4ed"/>
          <text x="70" y="142" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="10" fill="#1a3a2d">No. 06</text>
          <line x1="58" y1="148" x2="82" y2="148" stroke="#c8aa7a" stroke-width="0.5"/>
          <text x="70" y="164" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">EYE</text>
          <text x="70" y="174" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">CONCENTRATE</text>
        </svg>
      </div>
      <div class="product__meta">
        <div class="product__meta-top">
          <div>
            <h3>Eye Concentrate</h3>
            <p>Caffeine · Peptide-3 · Cucumber</p>
          </div>
          <span class="product__price">$92</span>
        </div>
        <button class="product__cta" type="button">Add to Cart</button>
      </div>
    </article>

    {% else %}
      {% for product in section.settings.collection.products limit: 6 %}
      <article class="product" data-color="forest">
        <button class="wish-btn" type="button" data-wishlist-toggle data-handle="{{ product.handle }}" data-title="{{ product.title | escape }}" data-price="{{ product.price | money }}" data-image="{{ product.featured_image | image_url: width: 200 }}" data-url="{{ product.url }}" aria-label="Save to wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg></button>
        <div class="product__media">
          <span class="product__tag">
            {% if forloop.first %}No. 01 · Bestseller{% else %}No. 0{{ forloop.index }}{% endif %}
          </span>
          <svg class="product__bottle" viewBox="0 0 140 220" aria-hidden="true">
            <defs>
              <linearGradient id="g{{ forloop.index }}" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#2a5a44"/><stop offset="1" stop-color="#1a3a2d"/></linearGradient>
            </defs>
            <rect x="56" y="6" width="28" height="26" rx="2" fill="#c8aa7a"/>
            <rect x="40" y="32" width="60" height="180" rx="6" fill="url(#g{{ forloop.index }})"/>
            <rect x="50" y="100" width="40" height="68" fill="#f9f4ed"/>
            <text x="70" y="124" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="10" fill="#1a3a2d">No. 0{{ forloop.index }}</text>
            <line x1="58" y1="130" x2="82" y2="130" stroke="#c8aa7a" stroke-width="0.5"/>
            <text x="70" y="146" text-anchor="middle" font-family="Cormorant Garamond" font-size="8" letter-spacing="2" fill="#1a3a2d">{{ product.title | truncate: 14, '' | upcase }}</text>
          </svg>
        </div>
        <div class="product__meta">
          <div class="product__meta-top">
            <div>
              <h3>{{ product.title }}</h3>
              <p>
                {%- if product.metafields.custom.subtitle != blank -%}
                  {{ product.metafields.custom.subtitle }}
                {%- else -%}
                  {{ product.description | strip_html | truncatewords: 6 }}
                {%- endif -%}
              </p>
            </div>
            <span class="product__price">{{ product.price | money }}</span>
          </div>
          <button class="product__cta" data-product-id="{{ product.selected_or_first_available_variant.id }}" type="button">Add to Cart</button>
        </div>
      </article>
      {% endfor %}
    {% endif %}
  </div>
    </div>
  </div>

  <div class="shop__foot">
    <a class="btn btn--ghost btn--dark" href="#all">
      <span>{{ section.settings.foot_link_label }}</span>
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Shop",
  "settings": [
    { "type": "html", "id": "heading", "label": "Heading", "default": "Six formulas.<br/><em>Zero shortcuts.</em>" },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "A complete pharmacist-built ritual. Begin with one, build to all six." },
    { "type": "text", "id": "foot_link_label", "label": "Footer link label", "default": "Explore the full apothecary" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [
    { "name": "Shop" }
  ]
}
{% endschema %}
