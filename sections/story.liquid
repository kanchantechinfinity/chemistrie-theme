<!-- ───── Brand Story — chapters ───── -->
<section class="story" id="our-story" data-screen-label="10 Brand Story">
  <div class="story__intro">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="display-h">{{ section.settings.heading }}</h2>
    <p class="story__lede">{{ section.settings.lede }}</p>
  </div>

  <ol class="story__chapters">

    <li class="story__chapter">
      <div class="story__chapter-meta">
        <span class="story__year">{{ section.settings.chapter_1_year }}</span>
        <span class="story__roman">— I —</span>
      </div>
      <div class="story__chapter-body">
        <h3>{{ section.settings.chapter_1_heading }}</h3>
        <p>{{ section.settings.chapter_1_body }}</p>
      </div>
      <div class="story__chapter-photo">
        <svg viewBox="0 0 400 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="st1" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#dec39a"/><stop offset="1" stop-color="#8a6f48"/></linearGradient>
          </defs>
          <rect width="400" height="500" fill="url(#st1)"/>
          <rect y="320" width="400" height="180" fill="#1a3a2d" opacity=".7"/>
          <rect x="190" y="180" width="20" height="160" fill="#0e2118"/>
          <rect x="100" y="170" width="200" height="10" rx="5" fill="#0e2118"/>
          <circle cx="120" cy="200" r="22" fill="#c8aa7a"/>
          <circle cx="280" cy="200" r="22" fill="#c8aa7a"/>
          <line x1="120" y1="178" x2="120" y2="200" stroke="#0e2118" stroke-width="2"/>
          <line x1="280" y1="178" x2="280" y2="200" stroke="#0e2118" stroke-width="2"/>
          <ellipse cx="200" cy="340" rx="100" ry="6" fill="#000" opacity=".3"/>
          <text x="40" y="470" font-family="JetBrains Mono,monospace" font-size="9" fill="#c8aa7a" letter-spacing="2">CHAPTER I · {{ section.settings.chapter_1_year }}</text>
        </svg>
      </div>
    </li>

    <li class="story__chapter story__chapter--reverse">
      <div class="story__chapter-meta">
        <span class="story__year">{{ section.settings.chapter_2_year }}</span>
        <span class="story__roman">— II —</span>
      </div>
      <div class="story__chapter-body">
        <h3>{{ section.settings.chapter_2_heading }}</h3>
        <p>{{ section.settings.chapter_2_body }}</p>
      </div>
      <div class="story__chapter-photo">
        <svg viewBox="0 0 400 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="st2" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#3d6b54"/><stop offset="1" stop-color="#1a3a2d"/></linearGradient>
          </defs>
          <rect width="400" height="500" fill="url(#st2)"/>
          <ellipse cx="200" cy="420" rx="120" ry="14" fill="#000" opacity=".4"/>
          <rect x="174" y="120" width="52" height="60" rx="4" fill="#c8aa7a"/>
          <path d="M150 180 Q150 168 180 168 H220 Q250 168 250 180 V410 Q250 432 220 432 H180 Q150 432 150 410 Z" fill="#0e2118"/>
          <rect x="160" y="260" width="80" height="120" fill="#f9f4ed"/>
          <text x="200" y="290" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="14" fill="#1a3a2d">No. 01</text>
          <line x1="172" y1="300" x2="228" y2="300" stroke="#c8aa7a" stroke-width="0.5"/>
          <text x="200" y="320" text-anchor="middle" font-family="Cormorant Garamond" font-size="10" letter-spacing="2" fill="#1a3a2d">RENEWAL</text>
          <text x="200" y="334" text-anchor="middle" font-family="Cormorant Garamond" font-size="10" letter-spacing="2" fill="#1a3a2d">SERUM</text>
          <text x="40" y="470" font-family="JetBrains Mono,monospace" font-size="9" fill="#c8aa7a" letter-spacing="2">CHAPTER II · {{ section.settings.chapter_2_year }}</text>
        </svg>
      </div>
    </li>

    <li class="story__chapter">
      <div class="story__chapter-meta">
        <span class="story__year">{{ section.settings.chapter_3_year }}</span>
        <span class="story__roman">— III —</span>
      </div>
      <div class="story__chapter-body">
        <h3>{{ section.settings.chapter_3_heading }}</h3>
        <p>{{ section.settings.chapter_3_body }}</p>
      </div>
      <div class="story__chapter-photo">
        <svg viewBox="0 0 400 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="st3" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#ebe3d2"/><stop offset="1" stop-color="#c8aa7a"/></linearGradient>
          </defs>
          <rect width="400" height="500" fill="url(#st3)"/>
          <g transform="rotate(-3 200 250)">
            <rect x="60" y="140" width="280" height="240" fill="#f9f4ed"/>
            <line x1="80" y1="190" x2="320" y2="190" stroke="#1a3a2d" stroke-width="1"/>
            <text x="80" y="184" font-family="Cormorant Garamond" font-style="italic" font-size="18" fill="#1a3a2d">— Waiting List, Vol. III</text>
            <text x="80" y="218" font-family="Cormorant Garamond" font-style="italic" font-size="13" fill="#1a3a2d">1.  Mrs. Eleanor R. — Houston</text>
            <text x="80" y="242" font-family="Cormorant Garamond" font-style="italic" font-size="13" fill="#1a3a2d">2.  Priya S. — Austin</text>
            <text x="80" y="266" font-family="Cormorant Garamond" font-style="italic" font-size="13" fill="#1a3a2d">3.  Camille D. — New Orleans</text>
            <text x="80" y="290" font-family="Cormorant Garamond" font-style="italic" font-size="13" fill="#1a3a2d">4.  Marisol M. — Houston</text>
            <text x="80" y="314" font-family="Cormorant Garamond" font-style="italic" font-size="13" fill="#1a3a2d">5.  Aanya P. — Dallas</text>
            <text x="80" y="338" font-family="Cormorant Garamond" font-style="italic" font-size="13" fill="#1a3a2d">6.  Linnea H. — Houston</text>
          </g>
          <text x="40" y="470" font-family="JetBrains Mono,monospace" font-size="9" fill="#1a3a2d" letter-spacing="2">CHAPTER III · {{ section.settings.chapter_3_year }}</text>
        </svg>
      </div>
    </li>

    <li class="story__chapter story__chapter--reverse">
      <div class="story__chapter-meta">
        <span class="story__year">{{ section.settings.chapter_4_year }}</span>
        <span class="story__roman">— IV —</span>
      </div>
      <div class="story__chapter-body">
        <h3>{{ section.settings.chapter_4_heading }}</h3>
        <p>{{ section.settings.chapter_4_body }}</p>
      </div>
      <div class="story__chapter-photo">
        <svg viewBox="0 0 400 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="st4" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#0e2118"/><stop offset="1" stop-color="#1a3a2d"/></linearGradient>
          </defs>
          <rect width="400" height="500" fill="url(#st4)"/>
          <text x="200" y="230" text-anchor="middle" font-family="Cormorant Garamond" font-weight="500" font-size="38" fill="#f9f4ed" letter-spacing="12">CHEMISTRIE</text>
          <line x1="120" y1="260" x2="280" y2="260" stroke="#c8aa7a" stroke-width="0.5"/>
          <text x="200" y="290" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-size="16" fill="#c8aa7a">est. Houston, {{ section.settings.chapter_4_year }}</text>
          <text x="200" y="320" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#dec39a" letter-spacing="3">A PHARMACIST'S MAISON</text>
          <text x="40" y="470" font-family="JetBrains Mono,monospace" font-size="9" fill="#c8aa7a" letter-spacing="2">CHAPTER IV · {{ section.settings.chapter_4_year }}</text>
        </svg>
      </div>
    </li>

    <li class="story__chapter">
      <div class="story__chapter-meta">
        <span class="story__year">{{ section.settings.chapter_5_year }}</span>
        <span class="story__roman">— V —</span>
      </div>
      <div class="story__chapter-body">
        <h3>{{ section.settings.chapter_5_heading }}</h3>
        <p>{{ section.settings.chapter_5_body }}</p>
        <a href="#shop" class="story__chapter-cta">
          <span>Step inside the maison</span>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <div class="story__chapter-photo">
        <svg viewBox="0 0 400 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="st5" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#6c8f7b"/><stop offset="1" stop-color="#1a3a2d"/></linearGradient>
          </defs>
          <rect width="400" height="500" fill="url(#st5)"/>
          <rect y="380" width="400" height="20" fill="#0e2118"/>
          <g transform="translate(50 220)"><rect width="36" height="160" rx="3" fill="#1a3a2d"/><rect x="4" y="70" width="28" height="56" fill="#f9f4ed"/></g>
          <g transform="translate(110 200)"><rect width="36" height="180" rx="3" fill="#3d6b54"/><rect x="4" y="80" width="28" height="60" fill="#f9f4ed"/></g>
          <g transform="translate(170 230)"><rect width="36" height="150" rx="3" fill="#c8aa7a"/><rect x="4" y="60" width="28" height="56" fill="#f9f4ed"/></g>
          <g transform="translate(230 210)"><rect width="36" height="170" rx="3" fill="#1a3a2d"/><rect x="4" y="70" width="28" height="60" fill="#f9f4ed"/></g>
          <g transform="translate(290 240)"><rect width="36" height="140" rx="3" fill="#0e2118"/><rect x="4" y="60" width="28" height="50" fill="#f9f4ed"/></g>
          <ellipse cx="200" cy="400" rx="180" ry="6" fill="#000" opacity=".5"/>
          <text x="40" y="470" font-family="JetBrains Mono,monospace" font-size="9" fill="#c8aa7a" letter-spacing="2">CHAPTER V · {{ section.settings.chapter_5_year }}</text>
        </svg>
      </div>
    </li>

  </ol>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— The Brand Story —" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Five quiet chapters.<br/><em>One bench.</em>" },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "Chemistrie was not founded in a boardroom. It was founded one milligram at a time, over a decade, on a single compounding bench in Houston." },

    { "type": "header", "content": "Chapter I" },
    { "type": "text", "id": "chapter_1_year", "label": "Year", "default": "2014" },
    { "type": "text", "id": "chapter_1_heading", "label": "Heading", "default": "The bench, on Heights Boulevard." },
    { "type": "textarea", "id": "chapter_1_body", "label": "Body", "default": "Dr. A and Dr. M meet across the same compounding bench in Houston. A decade of weighing actives by the milligram begins — for patients, for partners, for the women they go home to." },

    { "type": "header", "content": "Chapter II" },
    { "type": "text", "id": "chapter_2_year", "label": "Year", "default": "2018" },
    { "type": "text", "id": "chapter_2_heading", "label": "Heading", "default": "The first wife. The first formula." },
    { "type": "textarea", "id": "chapter_2_body", "label": "Body", "default": "Dr. M's wife asks for a retinol that does not burn. He compounds 0.05% retinaldehyde with niacinamide in a backroom mortar. Within four weeks, six other patients are asking for the same bottle." },

    { "type": "header", "content": "Chapter III" },
    { "type": "text", "id": "chapter_3_year", "label": "Year", "default": "2022" },
    { "type": "text", "id": "chapter_3_heading", "label": "Heading", "default": "The patient list becomes a waiting list." },
    { "type": "textarea", "id": "chapter_3_body", "label": "Body", "default": "Friends of friends. A dermatology nurse's daughter. A schoolteacher in Austin. The bench cannot pour fast enough. The pharmacists begin labelling batches by hand, numbering each bottle as it leaves." },

    { "type": "header", "content": "Chapter IV" },
    { "type": "text", "id": "chapter_4_year", "label": "Year", "default": "2025" },
    { "type": "text", "id": "chapter_4_heading", "label": "Heading", "default": "The maison takes a name." },
    { "type": "textarea", "id": "chapter_4_body", "label": "Body", "default": "A glassblower three blocks away. A letterpress in the same city. A photographer who shoots only in west afternoon light. The house is named on a Tuesday — Chemistrie, for the chemistry of patience, hands, and a woman's nightly ritual." },

    { "type": "header", "content": "Chapter V" },
    { "type": "text", "id": "chapter_5_year", "label": "Year", "default": "2026" },
    { "type": "text", "id": "chapter_5_heading", "label": "Heading", "default": "Today. And the women, still." },
    { "type": "textarea", "id": "chapter_5_body", "label": "Body", "default": "Twelve formulas. Two hundred bottles a batch. A pharmacist on the phone, always. Chemistrie is the same bench it always was — only now, with a door open to you." }
  ],
  "presets": [
    { "name": "Brand Story" }
  ]
}
{% endschema %}
