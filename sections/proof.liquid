<!-- ───── Proof strip ───── -->
<section class="proof" data-screen-label="07 Proof">
  <div class="proof__head">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="display-h">{{ section.settings.heading }}</h2>
  </div>

  <div class="proof__grid">
    {% for block in section.blocks %}
    <div class="proof__cell"{{ block.shopify_attributes }}>
      {% if block.settings.unit != blank %}
      <span class="proof__num" data-count="{{ block.settings.count }}" data-suffix=""><span class="proof__num-n">0</span><span class="proof__num-u">{{ block.settings.unit }}</span></span>
      {% else %}
      <span class="proof__num" data-count="{{ block.settings.count }}" data-suffix="{{ block.settings.suffix }}">0{{ block.settings.suffix }}</span>
      {% endif %}
      <span class="proof__label">{{ block.settings.label }}</span>
    </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Proof stats",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— The Pharmacy Standard —" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Numbers, not <em>noise.</em>" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "number", "id": "count", "label": "Count-up target", "default": 0 },
        { "type": "text", "id": "suffix", "label": "Suffix (e.g. %)", "default": "" },
        { "type": "text", "id": "unit", "label": "Unit word (optional — e.g. days; overrides suffix)", "default": "" },
        { "type": "text", "id": "label", "label": "Label", "default": "Fillers, fragrance, fluff." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Proof stats",
      "blocks": [
        { "type": "stat", "settings": { "count": 0, "suffix": "", "unit": "", "label": "Fillers, fragrance, fluff." } },
        { "type": "stat", "settings": { "count": 100, "suffix": "%", "unit": "", "label": "Pharmacist-formulated. Every batch." } },
        { "type": "stat", "settings": { "count": 28, "suffix": "", "unit": "", "label": "Clinically respected actives." } },
        { "type": "stat", "settings": { "count": 14, "suffix": "", "unit": "days", "label": "Money-back, no-questions ritual trial." } }
      ]
    }
  ]
}
{% endschema %}
