<section class="page-section ritual-shop" data-screen-label="Shop the Ritual">
  <div class="page-section__inner">
    <div class="page-section__head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="display-h">{{ section.settings.heading }}</h2>
    </div>

    <div class="rshop__grid">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: 4 -%}
        <article class="pcard">
          <a class="pcard__link" href="{{ product.url }}" aria-label="{{ product.title | escape }}"></a>
          <button class="wish-btn" type="button" data-wishlist-toggle data-handle="{{ product.handle }}" data-title="{{ product.title | escape }}" data-price="{{ product.price | money }}" data-image="{{ product.featured_image | image_url: width: 200 }}" data-url="{{ product.url }}" aria-label="Save to wishlist">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg>
          </button>
          <div class="pcard__media">
            {%- if product.featured_image -%}
              <img class="pcard__img" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="600" height="600">
              {%- if product.images.size > 1 -%}
                <img class="pcard__img pcard__img--alt" src="{{ product.images[1] | image_url: width: 600 }}" alt="" loading="lazy" width="600" height="600">
              {%- endif -%}
            {%- else -%}
              <img src="{{ 'stock-product.jpg' | asset_url }}" alt="{{ product.title | escape }}" loading="lazy" class="pcard__placeholder">
              {%- comment -%} Temporary Unsplash stock photo — replace with a real product image in Shopify admin {%- endcomment -%}
            {%- endif -%}
          </div>
          <div class="pcard__body">
            <div class="pcard__row">
              <a class="pcard__name" href="{{ product.url }}">{{ product.title }}</a>
              <span class="pcard__price">{{ product.price | money }}</span>
            </div>
            <button class="pcard__btn product__cta" data-product-id="{{ product.selected_or_first_available_variant.id }}" type="button">Add to Cart</button>
          </div>
        </article>
        {%- endfor -%}
      {%- else -%}
        {%- assign fallback_names = 'Velvet,Lumina,Cashmere,Peptide Cream' | split: ',' -%}
        {%- assign fallback_prices = '$36,$68,$52,$118' | split: ',' -%}
        {%- for name in fallback_names -%}
        <article class="pcard">
          <button class="wish-btn" type="button" data-wishlist-toggle data-handle="{{ name | handleize }}" data-title="{{ name | escape }}" data-price="{{ fallback_prices[forloop.index0] }}" data-image="" data-url="#" aria-label="Save to wishlist">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg>
          </button>
          <div class="pcard__media">
            <img src="{{ 'stock-product.jpg' | asset_url }}" alt="{{ name | escape }}" loading="lazy" class="pcard__placeholder">
            {%- comment -%} Temporary Unsplash stock photo — replace with a real product image in Shopify admin {%- endcomment -%}
          </div>
          <div class="pcard__body">
            <div class="pcard__row">
              <span class="pcard__name">{{ name }}</span>
              <span class="pcard__price">{{ fallback_prices[forloop.index0] }}</span>
            </div>
            <button class="pcard__btn product__cta" type="button">Add to Cart</button>
          </div>
        </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="rshop__foot">
      <a class="rshop__pdf" href="{{ section.settings.pdf_url | default: '#' }}">Download the Ritual Card (PDF) →</a>
      <p class="rshop__caption">{{ section.settings.caption }}</p>
    </div>
  </div>
</section>

{% stylesheet %}
.ritual-shop { background: var(--c-cream); }
.pcard__link { position: absolute; inset: 0; z-index: 1; }
.pcard .wish-btn, .pcard .product__cta { position: relative; z-index: 2; }
.pcard__name { display: inline-block; }
.rshop__grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: clamp(16px, 2vw, 26px);
}
.pcard__placeholder { width: 100%; height: 100%; object-fit: cover; }
.rshop__foot { margin-top: clamp(40px, 5vw, 64px); display: flex; flex-direction: column; gap: 10px; }
.rshop__pdf { align-self: flex-start; font-size: 13px; letter-spacing: .12em; text-transform: uppercase; color: var(--c-forest); border-bottom: 1px solid var(--c-tan); padding-bottom: 3px; transition: color .3s; }
.rshop__pdf:hover { color: var(--c-tan); }
.rshop__caption { font-size: 14px; line-height: 1.6; color: rgba(26,58,45,.65); max-width: 52ch; margin: 0; }
@media (max-width: 1000px) { .rshop__grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 640px) { .rshop__grid { grid-template-columns: 1fr 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Ritual Shop",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— Shop this ritual —" },
    { "type": "html", "id": "heading", "label": "Heading (supports <em>/<br>)", "default": "The whole ritual,<br/><em>in five bottles.</em>" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "url", "id": "pdf_url", "label": "Ritual Card PDF URL" },
    { "type": "textarea", "id": "caption", "label": "Caption", "default": "A printable card version of the ritual, to keep by the mirror. Coming soon." }
  ],
  "presets": [
    { "name": "Ritual Shop" }
  ]
}
{% endschema %}
