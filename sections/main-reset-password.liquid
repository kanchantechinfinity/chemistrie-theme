<section class="page-hero page-hero--short" data-screen-label="Reset password">
  <div class="page-hero__inner cust__hero-inner">
    <span class="eyebrow eyebrow--light">— Your account —</span>
    <h1 class="display-h display-h--light page-hero__title">Set a new password</h1>
  </div>
</section>

<section class="page-section page-section--paper cust">
  <div class="page-section__inner cust__wrap">
    <div class="cust__card">
      {%- form 'reset_customer_password', class: 'cust__form' -%}
        {%- if form.errors -%}<p class="cust__error">{{ form.errors | default_errors }}</p>{%- endif -%}
        <label class="cust__label" for="rp-pass">New password</label>
        <input class="cust__input" id="rp-pass" type="password" name="customer[password]" autocomplete="new-password" required>
        <label class="cust__label" for="rp-conf">Confirm password</label>
        <input class="cust__input" id="rp-conf" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
        <button type="submit" class="btn btn--primary cust__submit">Reset password</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
.page-hero--short { padding-top: clamp(110px, 13vw, 170px); padding-bottom: clamp(40px, 5vw, 64px); }
.cust__hero-inner { text-align: center; }
.cust__wrap { max-width: 460px; margin: 0 auto; }
.cust__card { background: var(--c-cream); border: 1px solid var(--c-line); border-radius: 16px; padding: clamp(28px, 4vw, 44px); }
.cust__form { display: flex; flex-direction: column; }
.cust__label { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--c-ink-mute); margin: 16px 0 8px; }
.cust__label:first-of-type { margin-top: 0; }
.cust__input { padding: 13px 16px; border: 1px solid var(--c-line); border-radius: 10px; background: var(--c-paper); font-family: var(--ff-body); font-size: 15px; color: var(--c-forest); }
.cust__submit { margin-top: 24px; justify-content: center; }
.cust__error { color: #a0402f; margin: 0 0 16px; font-size: 14px; }
{% endstylesheet %}

{% schema %}
{ "name": "Reset password", "settings": [] }
{% endschema %}
