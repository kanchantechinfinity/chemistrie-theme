<!-- ───── Active Index — Pinned horizontal showcase ───── -->
<section class="actives" id="actives" data-screen-label="06 Active Index">
  <div class="actives__intro">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="display-h">{{ section.settings.heading }}</h2>
    <p class="actives__lede">{{ section.settings.lede }}</p>
  </div>

  <div class="actives__pin" id="activesPin">
    <div class="actives__track" id="activesTrack">
{% for block in section.blocks %}
      <article class="active-card{% if block.settings.is_hero %} active-card--hero{% endif %}" data-idx="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <span class="active-card__num">N°<strong>{{ forloop.index | prepend: '0' | slice: -2, 2 }}</strong></span>
        <div class="active-card__mol">
          {%- case block.settings.molecule -%}
          {%- when 1 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <circle cx="120" cy="120" r="68"/>
            <circle cx="120" cy="52" r="7" fill="currentColor"/>
            <circle cx="188" cy="120" r="7" fill="currentColor"/>
            <circle cx="120" cy="188" r="7" fill="currentColor"/>
            <circle cx="52" cy="120" r="7" fill="currentColor"/>
            <line x1="120" y1="58" x2="120" y2="98"/>
            <line x1="120" y1="142" x2="120" y2="182"/>
            <line x1="58" y1="120" x2="98" y2="120"/>
            <line x1="142" y1="120" x2="182" y2="120"/>
          </svg>
          {%- when 2 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <path d="M120 40L172 70V130L120 160L68 130V70Z"/>
            <circle cx="120" cy="40" r="6" fill="currentColor"/>
            <circle cx="172" cy="70" r="6" fill="currentColor"/>
            <circle cx="172" cy="130" r="6" fill="currentColor"/>
            <circle cx="120" cy="160" r="6" fill="currentColor"/>
            <circle cx="68" cy="130" r="6" fill="currentColor"/>
            <circle cx="68" cy="70" r="6" fill="currentColor"/>
            <line x1="120" y1="160" x2="120" y2="200"/>
            <circle cx="120" cy="200" r="6" fill="currentColor"/>
          </svg>
          {%- when 3 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <circle cx="90" cy="120" r="32"/>
            <circle cx="150" cy="120" r="32"/>
            <line x1="122" y1="120" x2="118" y2="120" stroke-width="2"/>
            <circle cx="60" cy="90" r="5" fill="currentColor"/>
            <circle cx="180" cy="90" r="5" fill="currentColor"/>
            <circle cx="60" cy="150" r="5" fill="currentColor"/>
            <circle cx="180" cy="150" r="5" fill="currentColor"/>
          </svg>
          {%- when 4 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <path d="M120 50C90 50 70 80 70 110C70 140 90 170 120 190C150 170 170 140 170 110C170 80 150 50 120 50Z"/>
            <line x1="120" y1="50" x2="120" y2="190"/>
            <line x1="80" y1="120" x2="160" y2="120"/>
            <circle cx="120" cy="50" r="5" fill="currentColor"/>
            <circle cx="120" cy="190" r="5" fill="currentColor"/>
          </svg>
          {%- when 5 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <polygon points="120,50 175,90 155,160 85,160 65,90"/>
            <circle cx="120" cy="50" r="6" fill="currentColor"/>
            <circle cx="175" cy="90" r="6" fill="currentColor"/>
            <circle cx="155" cy="160" r="6" fill="currentColor"/>
            <circle cx="85" cy="160" r="6" fill="currentColor"/>
            <circle cx="65" cy="90" r="6" fill="currentColor"/>
            <line x1="120" y1="120" x2="120" y2="190"/>
          </svg>
          {%- when 6 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <path d="M60 120Q80 60 120 90T180 60T180 120T140 180T80 150T60 120Z"/>
            <circle cx="80" cy="100" r="5" fill="currentColor"/>
            <circle cx="120" cy="90" r="5" fill="currentColor"/>
            <circle cx="160" cy="100" r="5" fill="currentColor"/>
            <circle cx="140" cy="160" r="5" fill="currentColor"/>
          </svg>
          {%- when 7 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <path d="M60 90L120 60L180 90L180 150L120 180L60 150Z"/>
            <line x1="60" y1="90" x2="120" y2="120"/>
            <line x1="120" y1="120" x2="180" y2="90"/>
            <line x1="120" y1="120" x2="120" y2="180"/>
            <circle cx="120" cy="120" r="6" fill="currentColor"/>
          </svg>
          {%- when 8 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <ellipse cx="120" cy="120" rx="68" ry="40"/>
            <ellipse cx="120" cy="120" rx="40" ry="68"/>
            <circle cx="120" cy="120" r="5" fill="currentColor"/>
          </svg>
          {%- when 9 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <path d="M120 60L120 180M90 90L150 90M90 150L150 150M70 120L170 120"/>
            <circle cx="120" cy="60" r="6" fill="currentColor"/>
            <circle cx="120" cy="180" r="6" fill="currentColor"/>
            <circle cx="70" cy="120" r="6" fill="currentColor"/>
            <circle cx="170" cy="120" r="6" fill="currentColor"/>
          </svg>
          {%- when 10 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <circle cx="80" cy="120" r="28"/>
            <circle cx="120" cy="120" r="40"/>
            <circle cx="160" cy="120" r="28"/>
            <circle cx="80" cy="120" r="5" fill="currentColor"/>
            <circle cx="160" cy="120" r="5" fill="currentColor"/>
          </svg>
          {%- when 11 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <path d="M70 70L170 70L170 170L70 170Z"/>
            <line x1="70" y1="120" x2="170" y2="120"/>
            <line x1="120" y1="70" x2="120" y2="170"/>
            <circle cx="120" cy="120" r="6" fill="currentColor"/>
          </svg>
          {%- when 12 -%}
          <svg viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.1">
            <path d="M120 60Q160 100 120 140Q80 100 120 60ZM120 100Q160 140 120 180Q80 140 120 100Z"/>
            <circle cx="120" cy="60" r="5" fill="currentColor"/>
            <circle cx="120" cy="180" r="5" fill="currentColor"/>
          </svg>
          {%- endcase -%}
        </div>
        <span class="active-card__tier">{{ block.settings.tier }}</span>
        <h3 class="active-card__name">{{ block.settings.name }}</h3>
        <span class="active-card__dose">{{ block.settings.dose }}</span>
        <p class="active-card__desc">{{ block.settings.description }}</p>
        <dl class="active-card__specs">
          <div><dt>Source</dt><dd>{{ block.settings.source }}</dd></div>
          <div><dt>Half-life</dt><dd>{{ block.settings.half_life }}</dd></div>
          <div><dt>Found in</dt><dd>{{ block.settings.found_in }}</dd></div>
        </dl>
      </article>
{% endfor %}
    </div>

    <!-- Progress bar -->
    <div class="actives__progress">
      <div class="actives__counter">
        <span class="actives__counter-current" id="activesCurrent">01</span>
        <span class="actives__counter-sep">/</span>
        <span class="actives__counter-total">{{ section.blocks.size }}</span>
      </div>
      <div class="actives__progress-track">
        <div class="actives__progress-fill" id="activesProgress"></div>
      </div>
      <div class="actives__progress-scroll">
        <span class="actives__progress-label">Scroll to advance</span>
        <span class="actives__progress-arrow">→</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Active Index",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— The Active Index —" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Twelve ingredients,<br/>scroll-by-<em>scroll.</em>" },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "Each active, one at a time. Concentration, source, half-life, the formula it lives in. Scroll horizontally — the pharmacist will hand you the next." }
  ],
  "blocks": [
    {
      "type": "active",
      "name": "Active",
      "settings": [
        { "type": "checkbox", "id": "is_hero", "label": "Hero active (larger card)", "default": false },
        { "type": "range", "id": "molecule", "label": "Molecule diagram (1–12)", "min": 1, "max": 12, "step": 1, "default": 1 },
        { "type": "text", "id": "tier", "label": "Tier", "default": "— Hero active" },
        { "type": "text", "id": "name", "label": "Name", "default": "Retinaldehyde" },
        { "type": "text", "id": "dose", "label": "Dose", "default": "0.05%" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Eleven times faster than retinol. Half the irritation. The dose only a pharmacist would risk." },
        { "type": "text", "id": "source", "label": "Source", "default": "Switzerland · USP" },
        { "type": "text", "id": "half_life", "label": "Half-life", "default": "12 mo · sealed" },
        { "type": "text", "id": "found_in", "label": "Found in", "default": "N°01 Renewal" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Active Index",
      "blocks": [
        { "type": "active", "settings": { "is_hero": true, "molecule": 1, "tier": "— Hero active", "name": "Retinaldehyde", "dose": "0.05%", "description": "Eleven times faster than retinol. Half the irritation. The dose only a pharmacist would risk.", "source": "Switzerland · USP", "half_life": "12 mo · sealed", "found_in": "N°01 Renewal" } },
        { "type": "active", "settings": { "is_hero": false, "molecule": 2, "tier": "— Hero active", "name": "L-Ascorbic Acid", "dose": "15%", "description": "Stabilised with ferulic and tocopherol. The pharmacist's gold standard for brightening.", "source": "Scotland · USP", "half_life": "8 mo · amber", "found_in": "N°02 Vit-C" } },
        { "type": "active", "settings": { "is_hero": true, "molecule": 3, "tier": "— Hero active", "name": "Niacinamide", "dose": "4%", "description": "Refines pore visibility, reinforces barrier. Universally well-tolerated.", "source": "USP · pH 5.4", "half_life": "36 months", "found_in": "N°01 · 04 · 06" } },
        { "type": "active", "settings": { "is_hero": true, "molecule": 4, "tier": "— Hero active", "name": "Bakuchiol", "dose": "1%", "description": "Botanical retinol-alternative for pregnancy and the most sensitive nights.", "source": "India · botanical", "half_life": "24 months", "found_in": "N°03 Golden Oil" } },
        { "type": "active", "settings": { "is_hero": false, "molecule": 5, "tier": "— Supporting", "name": "Mandelic Acid", "dose": "8%", "description": "The kindest AHA. Large molecule, slow penetration, dignified results.", "source": "Almond · USP", "half_life": "18 months", "found_in": "N°05 Tonic" } },
        { "type": "active", "settings": { "is_hero": false, "molecule": 6, "tier": "— Supporting", "name": "Peptide-5", "dose": "2%", "description": "Signals collagen synthesis. Daily, undramatic improvement.", "source": "Switzerland", "half_life": "24 months", "found_in": "N°04 Cream" } },
        { "type": "active", "settings": { "is_hero": true, "molecule": 7, "tier": "— Hero active", "name": "Ceramide Complex", "dose": "NP·AP·EOP", "description": "Three ceramides mirroring the lipid ratio of healthy young skin.", "source": "Japan · bio-id", "half_life": "30 months", "found_in": "N°04 Velvet" } },
        { "type": "active", "settings": { "is_hero": false, "molecule": 8, "tier": "— Supporting", "name": "Squalane", "dose": "100%", "description": "Plant-derived. Pharmaceutical-grade. Closes the ritual, never clogs.", "source": "Spain · olive", "half_life": "36 months", "found_in": "N°03 Oil" } },
        { "type": "active", "settings": { "is_hero": false, "molecule": 9, "tier": "— Supporting", "name": "Calendula", "dose": "3%", "description": "Anti-inflammatory infusion. The reason redness softens, not just hides.", "source": "Houston · fresh", "half_life": "9 months", "found_in": "N°04b Balm" } },
        { "type": "active", "settings": { "is_hero": true, "molecule": 10, "tier": "— Hero active", "name": "Hyaluronic, 3-MW", "dose": "2%", "description": "Low, mid and high molecular weights — together. Hydration at every layer.", "source": "Bio-fermented", "half_life": "24 months", "found_in": "Whole ritual" } },
        { "type": "active", "settings": { "is_hero": false, "molecule": 11, "tier": "— Supporting", "name": "Allantoin", "dose": "1%", "description": "Soothes, smooths, accelerates barrier repair after every active.", "source": "USP-grade", "half_life": "36 months", "found_in": "N°01 · 04" } },
        { "type": "active", "settings": { "is_hero": false, "molecule": 12, "tier": "— Supporting", "name": "Centella Asiatica", "dose": "5%", "description": "Madecassoside-rich. The bench's favourite calming active.", "source": "Korea · USP", "half_life": "24 months", "found_in": "N°05 Tonic" } }
      ]
    }
  ]
}
{% endschema %}
