<!-- ───── Instagram — horizontal reel slider ───── -->
<section class="insta" id="instagram" data-screen-label="11 Instagram">
  <div class="insta__intro">
    <div>
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="display-h">{{ section.settings.heading }}</h2>
    </div>
    <div class="insta__intro-right">
      <a class="insta__handle" href="{{ section.settings.instagram_url | default: '#' }}" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".7" fill="currentColor"/></svg>
        <span>{{ section.settings.handle }}</span>
        <em>· {{ section.settings.follower_count }}</em>
      </a>
      <div class="insta__nav" aria-label="Slider navigation">
        <button class="insta__arrow" data-dir="-1" aria-label="Previous">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <button class="insta__arrow" data-dir="1" aria-label="Next">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
    </div>
  </div>

  {%- if section.settings.feed_embed != blank -%}
  <div class="insta__feed-embed">
    {{ section.settings.feed_embed }}
  </div>
  {%- else -%}
  <div class="insta__slider-wrap">
    <div class="insta__slider" id="instaSlider">
      <article class="reel">
        <div class="reel__media">
          <img src="{{ 'stock-product.jpg' | asset_url }}" alt="One drop, eleven hours of patience." loading="lazy">
          {%- comment -%} Temporary Unsplash stock photo — replace via Shopify admin {%- endcomment -%}
          <span class="reel__play"><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
          <span class="reel__duration">0:42</span>
        </div>
        <div class="reel__meta">
          <p>One drop, eleven hours of patience.</p>
          <div class="reel__stats">
            <span><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 8a4 4 0 0 0-7-2 4 4 0 0 0-7 2c0 6 7 10 7 10s7-4 7-10z"/></svg> 2.4k</span>
            <span><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 12c0 4-4 7-9 7-1.5 0-3-.3-4-.7L3 20l1-3.7C3.4 15.2 3 13.7 3 12c0-4 4-7 9-7s9 3 9 7z"/></svg> 88</span>
          </div>
        </div>
      </article>

      <article class="reel">
        <div class="reel__media">
