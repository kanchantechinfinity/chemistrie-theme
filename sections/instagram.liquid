</section>

{% schema %}
{
  "name": "Instagram",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— The Bench, on Instagram —" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Find us <em>between</em><br/>the bottles." },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "handle", "label": "Handle", "default": "@chemistrie.co" },
    { "type": "text", "id": "follower_count", "label": "Follower count", "default": "21.4k" },
    { "type": "header", "content": "Live Instagram feed (optional)" },
    { "type": "paragraph", "content": "Paste an embed/widget code from an Instagram feed app (Instafeed, Elfsight, Behold, etc.). When filled, the live feed replaces the demo reels." },
    { "type": "html", "id": "feed_embed", "label": "Instagram feed embed code" }
  ],
  "presets": [
    { "name": "Instagram" }
  ]
}
{% endschema %}
