<section class="page-hero page-hero--short" data-screen-label="Account">
  <div class="page-hero__inner acct__hero-inner">
    <span class="eyebrow eyebrow--light">— Your account —</span>
    <h1 class="display-h display-h--light page-hero__title">{{ customer.first_name | default: 'Your account' }}</h1>
    <div class="acct__hero-links">
      <a href="{{ routes.account_addresses_url }}">Addresses</a>
      <a href="{{ routes.account_logout_url }}">Log out</a>
    </div>
  </div>
</section>

<section class="page-section page-section--paper acct">
  <div class="page-section__inner acct__grid">

    <aside class="acct__side">
      <h2 class="acct__side-title">Account details</h2>
      <p class="acct__name">{{ customer.name }}</p>
      <p class="acct__email">{{ customer.email }}</p>
      {%- if customer.default_address -%}
        <div class="acct__addr">{{ customer.default_address | format_address }}</div>
      {%- endif -%}
      <a href="{{ routes.account_addresses_url }}" class="btn btn--ghost btn--dark acct__addr-btn">Manage addresses</a>
    </aside>

    <div class="acct__main">
      <h2 class="acct__main-title">Order history</h2>
      {%- if customer.orders.size > 0 -%}
        <div class="acct__table-wrap">
          <table class="acct__table">
            <thead>
              <tr><th>Order</th><th>Date</th><th>Payment</th><th>Fulfillment</th><th class="acct__right">Total</th></tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                <tr>
                  <td><a href="{{ order.customer_url }}" class="acct__ordlink">{{ order.name }}</a></td>
                  <td>{{ order.created_at | date: '%b %-d, %Y' }}</td>
                  <td>{{ order.financial_status_label }}</td>
                  <td>{{ order.fulfillment_status_label }}</td>
                  <td class="acct__right">{{ order.total_price | money }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      {%- else -%}
        <div class="acct__empty">
          <p>You haven't placed any orders yet.</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Shop the Collection</a>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

{% stylesheet %}
.page-hero--short { padding-top: clamp(110px, 13vw, 170px); padding-bottom: clamp(40px, 5vw, 64px); }
.acct__hero-links { display: flex; gap: 20px; margin-top: 22px; font-size: 13px; letter-spacing: .06em; }
.acct__hero-links a { color: rgba(240,232,219,.7); text-decoration: underline; text-underline-offset: 3px; }
.acct__hero-links a:hover { color: var(--c-tan); }
.acct__grid { display: grid; grid-template-columns: 280px 1fr; gap: clamp(32px, 4vw, 64px); align-items: start; }
.acct__side { background: var(--c-cream); border: 1px solid var(--c-line); border-radius: 16px; padding: 28px; }
.acct__side-title, .acct__main-title { font-family: var(--ff-display); font-size: 24px; color: var(--c-forest); margin: 0 0 18px; }
.acct__name { font-weight: 500; margin: 0 0 4px; }
.acct__email { color: var(--c-ink-soft); margin: 0 0 16px; }
.acct__addr { font-size: 14px; line-height: 1.6; color: var(--c-ink-soft); }
.acct__addr-btn { margin-top: 18px; }
.acct__table-wrap { overflow-x: auto; }
.acct__table { width: 100%; border-collapse: collapse; font-size: 14px; }
.acct__table th { text-align: left; padding: 12px 16px; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--c-ink-mute); border-bottom: 1px solid var(--c-line); }
.acct__table td { padding: 16px; border-bottom: 1px solid var(--c-line-soft); color: var(--c-ink-soft); }
.acct__right { text-align: right; }
.acct__ordlink { color: var(--c-forest); font-weight: 500; text-decoration: underline; text-underline-offset: 3px; }
.acct__empty { display: flex; flex-direction: column; align-items: flex-start; gap: 18px; color: var(--c-ink-soft); }
@media (max-width: 820px) { .acct__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{ "name": "Account", "settings": [] }
{% endschema %}
