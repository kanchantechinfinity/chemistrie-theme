{%- assign threshold = settings.free_shipping_threshold | times: 100 -%}
<section class="page-hero page-hero--short" data-screen-label="Cart">
  <div class="page-hero__inner cart__hero-inner">
    <span class="eyebrow eyebrow--light">— {{ section.settings.eyebrow | default: 'Your bench' }} —</span>
    <h1 class="display-h display-h--light page-hero__title">{{ section.settings.heading | default: 'The Cart' }}</h1>
  </div>
</section>

<section class="page-section page-section--paper cart">
  <div class="page-section__inner">
    {%- if cart.item_count > 0 -%}

      {%- if threshold > 0 -%}
        {%- assign remaining = threshold | minus: cart.total_price -%}
        <div class="cart__ship {% if remaining <= 0 %}cart__ship--met{% endif %}">
          {%- if remaining > 0 -%}
            You're {{ remaining | money }} away from <strong>free shipping</strong>.
          {%- else -%}
            You've unlocked <strong>free shipping</strong>.
          {%- endif -%}
          <span class="cart__ship-bar"><span class="cart__ship-fill" style="width: {% if remaining <= 0 %}100{% else %}{{ cart.total_price | times: 100 | divided_by: threshold }}{% endif %}%;"></span></span>
        </div>
      {%- endif -%}

      <form action="{{ routes.cart_url }}" method="post" class="cart__form" novalidate>
        <div class="cart__grid">
          <div class="cart__items">
            <div class="cart__thead">
              <span>Product</span>
              <span>Quantity</span>
              <span class="cart__thead-price">Total</span>
            </div>
            {%- for item in cart.items -%}
              <div class="cart__item">
                <a class="cart__media" href="{{ item.url }}">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title, class: 'cart__img' }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'cart__img' }}
                  {%- endif -%}
                </a>
                <div class="cart__info">
                  <a class="cart__name" href="{{ item.url }}">{{ item.product.title }}</a>
                  {%- unless item.variant.title contains 'Default' -%}
                    <span class="cart__variant">{{ item.variant.title }}</span>
                  {%- endunless -%}
                  <span class="cart__unit">{{ item.original_price | money }} each</span>
                  {%- if item.line_level_discount_allocations != empty -%}
                    {%- for alloc in item.line_level_discount_allocations -%}
                      <span class="cart__discount">◆ {{ alloc.discount_application.title }} (−{{ alloc.amount | money }})</span>
                    {%- endfor -%}
                  {%- endif -%}
                  <a class="cart__remove" href="{{ item.url_to_remove }}">Remove</a>
                </div>
                <div class="cart__qty">
                  <label class="visually-hidden" for="updates_{{ item.key }}">Quantity for {{ item.title }}</label>
                  <input class="cart__qty-input" id="updates_{{ item.key }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0" inputmode="numeric">
                </div>
                <div class="cart__line-price">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s class="cart__line-was">{{ item.original_line_price | money }}</s>
                  {%- endif -%}
                  {{ item.final_line_price | money }}
                </div>
              </div>
            {%- endfor -%}
            <div class="cart__actions">
              <a href="{{ routes.all_products_collection_url }}" class="cart__continue">&larr; Continue shopping</a>
              <button type="submit" name="update" class="btn btn--ghost btn--dark">Update cart</button>
            </div>
          </div>

          <aside class="cart__summary">
            <h2 class="cart__summary-title">Order summary</h2>
            <div class="cart__row"><span>Subtotal</span><span>{{ cart.original_total_price | money }}</span></div>
            {%- if cart.cart_level_discount_applications != empty -%}
              {%- for d in cart.cart_level_discount_applications -%}
                <div class="cart__row cart__row--disc"><span>◆ {{ d.title }}</span><span>−{{ d.total_allocated_amount | money }}</span></div>
              {%- endfor -%}
            {%- elsif cart.total_discounts > 0 -%}
              <div class="cart__row cart__row--disc"><span>Discounts</span><span>−{{ cart.total_discounts | money }}</span></div>
            {%- endif -%}
            {%- if cart.total_discounts > 0 -%}
              <div class="cart__row cart__row--total"><span>Estimated total</span><span>{{ cart.total_price | money }}</span></div>
            {%- endif -%}
            <div class="cart__coupon">
              <label class="visually-hidden" for="cart-coupon">Coupon code</label>
              <input type="text" id="cart-coupon" class="cart__coupon-input" placeholder="Enter coupon code" autocomplete="off">
              <button type="button" class="cart__coupon-btn" id="cartCouponApply">Apply</button>
            </div>
            <p class="cart__coupon-hint" id="cartCouponHint" hidden></p>
            <div class="cart__row cart__row--note"><span>Shipping</span><span>Calculated at checkout</span></div>
            <label class="cart__note-label" for="cart-note">Order note</label>
            <textarea id="cart-note" name="note" class="cart__note" rows="2" placeholder="Add a note (gift message, delivery instructions)">{{ cart.note }}</textarea>
            <button type="submit" name="checkout" class="btn btn--primary cart__checkout">Checkout</button>
            <ul class="cart__trust">
              {%- if settings.free_shipping_threshold > 0 -%}<li>Free shipping over ${{ settings.free_shipping_threshold }}</li>{%- endif -%}
              <li>Compounded in Houston</li>
              <li>Secure checkout</li>
            </ul>
          </aside>
        </div>
      </form>

    {%- else -%}
      <div class="cart__empty">
        <h2 class="cart__empty-title">{{ section.settings.empty_heading | default: 'Your cart is empty.' }}</h2>
        <p class="cart__empty-sub">{{ section.settings.empty_text | default: 'Every formula is compounded by hand, in batches of 200. Find the one your skin has been waiting for.' }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ section.settings.empty_cta | default: 'Shop the Collection' }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.page-hero--short { padding-top: clamp(110px, 13vw, 170px); padding-bottom: clamp(40px, 5vw, 64px); }
.cart__hero-inner { text-align: center; display: flex; flex-direction: column; align-items: center; }
.cart__hero-inner .eyebrow, .cart__hero-inner .page-hero__title { max-width: 100%; margin-left: auto; margin-right: auto; text-align: center; }
.cart { padding-bottom: clamp(60px, 8vw, 100px); }
.cart .page-section__inner { max-width: var(--maxw); margin-inline: auto; }
.cart__ship { margin: 0 auto clamp(32px, 4vw, 48px); max-width: 720px; text-align: center; font-size: 14px; color: var(--c-ink-soft); }
.cart__ship--met { color: var(--c-forest); }
.cart__ship-bar { display: block; height: 6px; margin-top: 12px; border-radius: 999px; background: var(--c-line-soft); overflow: hidden; }
.cart__ship-fill { display: block; height: 100%; background: var(--c-forest); transition: width .5s var(--ease-out); }
.cart__grid { display: grid; grid-template-columns: 1fr 360px; gap: clamp(32px, 4vw, 64px); align-items: start; }
.cart__thead { display: grid; grid-template-columns: 1fr auto auto; gap: 20px; padding-bottom: 16px; border-bottom: 1px solid var(--c-line); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--c-ink-mute); }
.cart__thead-price { text-align: right; }
.cart__item { display: grid; grid-template-columns: 90px 1fr auto auto; gap: 20px; align-items: center; padding: 24px 0; border-bottom: 1px solid var(--c-line-soft); }
.cart__media { border-radius: 10px; overflow: hidden; background: var(--grad-cream); }
.cart__img { width: 90px; height: 90px; object-fit: cover; }
.cart__info { display: flex; flex-direction: column; gap: 4px; }
.cart__name { font-family: var(--ff-display); font-size: 21px; color: var(--c-forest); }
.cart__variant { font-size: 13px; color: var(--c-ink-mute); }
.cart__unit { font-size: 13px; color: var(--c-ink-soft); }
.cart__remove { margin-top: 6px; font-size: 12px; letter-spacing: .04em; color: var(--c-ink-mute); text-decoration: underline; align-self: flex-start; }
.cart__remove:hover { color: var(--c-forest); }
.cart__qty-input { width: 64px; padding: 10px; text-align: center; border: 1px solid var(--c-line); border-radius: 8px; background: var(--c-cream); font-family: var(--ff-body); font-size: 15px; color: var(--c-forest); }
.cart__line-price { font-size: 15px; color: var(--c-forest); text-align: right; white-space: nowrap; }
.cart__actions { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-top: 28px; flex-wrap: wrap; }
.cart__continue { font-size: 13px; letter-spacing: .04em; color: var(--c-ink-soft); }
.cart__continue:hover { color: var(--c-forest); }

.cart__summary { background: var(--c-cream); border: 1px solid var(--c-line); border-radius: 16px; padding: clamp(24px, 3vw, 36px); position: sticky; top: 100px; }
.cart__summary-title { font-family: var(--ff-display); font-size: 24px; color: var(--c-forest); margin: 0 0 20px; }
.cart__row { display: flex; justify-content: space-between; padding: 10px 0; font-size: 15px; color: var(--c-ink-soft); }
.cart__row--disc { color: var(--c-sage); }
.cart__row--total { font-family: var(--ff-display); font-size: 19px; color: var(--c-forest); border-top: 1px solid var(--c-line-soft); margin-top: 4px; padding-top: 14px; }
.cart__disc-hint { font-size: 12px; color: var(--c-ink-mute); margin: 8px 0 0; }
.cart__coupon { display: flex; gap: 8px; margin: 18px 0 6px; }
.cart__coupon-input { flex: 1; min-width: 0; padding: 12px 14px; border: 1px solid var(--c-line); border-radius: 10px; background: var(--c-cream); font-family: var(--ff-body); font-size: 14px; color: var(--c-forest); }
.cart__coupon-input::placeholder { color: var(--c-ink-mute); }
.cart__coupon-btn { flex: 0 0 auto; padding: 12px 22px; border-radius: 10px; background: var(--c-forest); color: var(--c-cream); font-size: 12px; letter-spacing: .12em; text-transform: uppercase; transition: background .3s; }
.cart__coupon-btn:hover { background: var(--c-forest-2); }
.cart__coupon-hint { font-size: 12px; color: var(--c-sage); margin: 0 0 6px; }
.cart__coupon-hint.is-error { color: #b5502e; }
.cart__discount { font-size: 12px; color: var(--c-sage); letter-spacing: .02em; }
.cart__line-was { color: var(--c-ink-mute); text-decoration: line-through; margin-right: 8px; font-size: 13px; }
.cart__row--note { border-bottom: 1px solid var(--c-line-soft); }
.cart__note-label { display: block; margin: 18px 0 8px; font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--c-ink-mute); }
.cart__note { width: 100%; padding: 12px 14px; border: 1px solid var(--c-line); border-radius: 10px; background: var(--c-paper); font-family: var(--ff-body); font-size: 14px; color: var(--c-forest); resize: vertical; }
.cart__checkout { width: 100%; justify-content: center; margin-top: 18px; }
.cart__trust { list-style: none; margin: 20px 0 0; padding: 18px 0 0; border-top: 1px solid var(--c-line-soft); display: flex; flex-direction: column; gap: 8px; font-size: 12px; letter-spacing: .04em; color: var(--c-ink-mute); }
.cart__trust li::before { content: "✓ "; color: var(--c-sage); }

.cart__empty { text-align: center; padding: 40px 0 80px; display: flex; flex-direction: column; align-items: center; gap: 20px; }
.cart__empty-title { font-family: var(--ff-display); font-size: clamp(28px, 4vw, 40px); color: var(--c-forest); margin: 0; }
.cart__empty-sub { max-width: 46ch; color: var(--c-ink-soft); line-height: 1.7; }
.visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }

@media (max-width: 900px) {
  .cart__grid { grid-template-columns: 1fr; }
  .cart__summary { position: static; }
}
@media (max-width: 560px) {
  .cart__thead { display: none; }
  .cart__item { grid-template-columns: 72px 1fr; grid-template-areas: "media info" "qty price"; }
  .cart__media { grid-area: media; }
  .cart__info { grid-area: info; }
  .cart__qty { grid-area: qty; }
  .cart__line-price { grid-area: price; text-align: right; align-self: center; }
  .cart__img { width: 72px; height: 72px; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  var btn = document.getElementById('cartCouponApply');
  var input = document.getElementById('cart-coupon');
  var hint = document.getElementById('cartCouponHint');
  if (!btn || !input) return;
  btn.addEventListener('click', function () {
    var code = (input.value || '').trim();
    if (!code) {
      if (hint) { hint.textContent = 'Enter a code to apply.'; hint.classList.add('is-error'); hint.hidden = false; }
      input.focus();
      return;
    }
    if (hint) { hint.textContent = 'Applying at checkout…'; hint.classList.remove('is-error'); hint.hidden = false; }
    window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent('/checkout');
  });
  input.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); btn.click(); }
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Cart",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your bench" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Cart" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "Your cart is empty." },
    { "type": "textarea", "id": "empty_text", "label": "Empty text", "default": "Every formula is compounded by hand, in batches of 200. Find the one your skin has been waiting for." },
    { "type": "text", "id": "empty_cta", "label": "Empty button label", "default": "Shop the Collection" }
  ],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
