<section class="page-section page-section--paper pcreds">
  <div class="page-section__inner">
    <div class="page-section__head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="display-h">{{ section.settings.heading }}</h2>
    </div>
    <div class="pcreds__grid">
      {%- for block in section.blocks -%}
        <div class="pcred" {{ block.shopify_attributes }}>
          <span class="pcred__num">{{ block.settings.number }}</span>
          <h3 class="pcred__title">{{ block.settings.title }}</h3>
          <p class="pcred__body">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.pcreds__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(28px, 4vw, 56px); }
.pcred { border-top: 1px solid var(--c-line); padding-top: 24px; }
.pcred__num { font-family: var(--ff-display); font-style: italic; font-size: 22px; color: var(--c-tan); }
.pcred__title { margin: 14px 0 0; font-family: var(--ff-display); font-size: clamp(21px, 2.2vw, 27px); font-weight: 500; color: var(--c-forest); line-height: 1.2; }
.pcred__body { margin: 14px 0 0; color: var(--c-ink-soft); line-height: 1.75; }
@media (max-width: 860px) { .pcreds__grid { grid-template-columns: 1fr; gap: 0; } .pcred { margin-top: 28px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Pharmacists Credentials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— The credentials —" },
    { "type": "html", "id": "heading", "label": "Heading (supports <em>/<br>)", "default": "What a<br/>compounding<br/><em>pharmacist does.</em>" }
  ],
  "blocks": [
    {
      "type": "cred",
      "name": "Credential",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "They weigh the actives themselves" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "A compounding pharmacist mixes each formula by hand, to the milligram — the same discipline used to prepare a prescription, brought to a bottle you keep on your shelf." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pharmacists Credentials",
      "blocks": [
        { "type": "cred", "settings": { "number": "01", "title": "They weigh the actives themselves", "body": "A compounding pharmacist mixes each formula by hand, to the milligram — the same discipline used to prepare a prescription, brought to a bottle you keep on your shelf." } },
        { "type": "cred", "settings": { "number": "02", "title": "They know how molecules behave", "body": "Which actives can share a bottle, which must be kept apart, what oil keeps vitamin C alive — this is pharmacy, not marketing, and it decides whether a formula actually works." } },
        { "type": "cred", "settings": { "number": "03", "title": "They answer for every batch", "body": "Each run is numbered and traceable to the pharmacist who compounded it. If a question comes in, a real person who mixed it is the one who answers." } }
      ]
    }
  ]
}
{% endschema %}
