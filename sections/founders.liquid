<!-- ───── Founder story ───── -->
<section class="founders" id="founders" data-screen-label="05 Founders">
  <div class="founders__media">
    <div class="founders__photo founders__photo--a">
      {% if section.settings.founder1_image != blank %}
        <img src="{{ section.settings.founder1_image | image_url: width: 600 }}" alt="{{ section.settings.founder1_name | escape }}" loading="lazy">
      {% else %}
        <img src="{{ 'founder-1.jpg' | asset_url }}" alt="{{ section.settings.founder1_name | escape }}" loading="lazy">
        {%- comment -%} Temporary Unsplash stock photo — replace via Shopify admin {%- endcomment -%}
      {% endif %}
    </div>
    <div class="founders__photo founders__photo--b">
      {% if section.settings.founder2_image != blank %}
        <img src="{{ section.settings.founder2_image | image_url: width: 600 }}" alt="{{ section.settings.founder2_name | escape }}" loading="lazy">
      {% else %}
        <img src="{{ 'founder-2.jpg' | asset_url }}" alt="{{ section.settings.founder2_name | escape }}" loading="lazy">
        {%- comment -%} Temporary Unsplash stock photo — replace via Shopify admin {%- endcomment -%}
      {% endif %}
    </div>
    <div class="founders__photo founders__photo--c">
      {% if section.settings.founder3_image != blank %}
        <img src="{{ section.settings.founder3_image | image_url: width: 600 }}" alt="{{ section.settings.founder3_name | escape }}" loading="lazy">
      {% else %}
        <img src="{{ 'founder-3.jpg' | asset_url }}" alt="{{ section.settings.founder3_name | escape }}" loading="lazy">
        {%- comment -%} Temporary Unsplash stock photo — replace via Shopify admin {%- endcomment -%}
      {% endif %}
    </div>
    <div class="founders__caption">
      <span class="founders__caption-mark">✦</span>
      <span>{{ section.settings.caption }}</span>
    </div>
  </div>

  <div class="founders__copy">
    <span class="eyebrow">— The Pharmacists —</span>
    <h2 class="display-h">{{ section.settings.heading }}</h2>
    <p class="founders__lede">
      {{ section.settings.lede }}
    </p>
    <p>
      {{ section.settings.paragraph1 }}
    </p>
    <p>
      {{ section.settings.paragraph2 }}
    </p>

    <div class="founders__signoff">
      <span class="founders__sig">{{ section.settings.sig }}</span>
      <span class="founders__sig-sub">{{ section.settings.sig_sub }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founders",
  "settings": [
    { "type": "text", "id": "caption", "label": "Photo caption", "default": "The founding pharmacists, photographed in the compounding lab — Houston, 2026." },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Three compounding<br/>pharmacists.<br/><em>One promise.</em>" },
    { "type": "header", "content": "Founder portraits" },
    { "type": "text", "id": "founder1_name", "label": "Founder 1 name", "default": "Dr. A —" },
    { "type": "image_picker", "id": "founder1_image", "label": "Founder 1 photo (optional)" },
    { "type": "text", "id": "founder2_name", "label": "Founder 2 name", "default": "Dr. M —" },
    { "type": "image_picker", "id": "founder2_image", "label": "Founder 2 photo (optional)" },
    { "type": "text", "id": "founder3_name", "label": "Founder 3 name", "default": "Dr. S —" },
    { "type": "image_picker", "id": "founder3_image", "label": "Founder 3 photo (optional)" },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "They met behind the same bench in Houston, weighing actives by the milligram for women who had been failed by everything on the shelf." },
    { "type": "textarea", "id": "paragraph1", "label": "Paragraph 1", "default": "Wives wanted retinol that didn't burn. Mothers wanted vitamin C that didn't oxidise in a week. Best friends wanted a moisturiser they could hand down. So they started making it — quietly, by hand, in concentrations the industry deemed too expensive to mass-produce." },
    { "type": "textarea", "id": "paragraph2", "label": "Paragraph 2", "default": "Chemistrie is what happened when their patient list became a waiting list." },
    { "type": "text", "id": "sig", "label": "Signature", "default": "— Dr. A, Dr. M & Dr. S" },
    { "type": "text", "id": "sig_sub", "label": "Signature subtitle", "default": "Compounding Pharmacists · Founders" }
  ],
  "presets": [
    { "name": "Founders" }
  ]
}
{% endschema %}
