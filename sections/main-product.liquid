{%- assign cv = product.selected_or_first_available_variant -%}
{%- assign mf = product.metafields.custom -%}
{%- comment -%} one-line benefit: metafield else first sentence of description {%- endcomment -%}
{%- if product.metafields.custom.benefit != blank -%}
  {%- assign benefit = product.metafields.custom.benefit -%}
{%- else -%}
  {%- assign benefit = product.description | strip_html | split: '. ' | first -%}
  {%- if benefit != blank -%}{%- assign benefit = benefit | append: '.' -%}{%- endif -%}
{%- endif -%}

{%- comment -%} Routine placement / warnings / feeling / benefits / how-to-use for the buy-box accordion (mirrors product-details.liquid's pd_key match — Shopify sections don't share Liquid scope, so this is intentionally duplicated) {%- endcomment -%}
{%- liquid
  assign _ph = product.handle | downcase
  assign _pt = product.title | downcase
  assign pd_key = ''
  if _ph contains 'velvet' or _pt contains 'velvet'
    assign pd_key = 'velvet'
  elsif _ph contains 'aura' or _pt contains 'aura'
    assign pd_key = 'aura'
  elsif _ph contains 'cashmere' or _pt contains 'cashmere'
    assign pd_key = 'cashmere'
  elsif _ph contains 'silken' or _pt contains 'silken'
    assign pd_key = 'silken'
  endif
-%}
{%- case pd_key -%}
  {%- when 'velvet' -%}
    {%- assign pd_routine_am = 'Velvet (Cleanse) → Lumina (Treat) → Cashmere (Moisturize) → SPF (Protect)' -%}
    {%- assign pd_routine_pm = 'Velvet (Cleanse) → Aura (Renew)' -%}
    {%- capture pd_warnings -%}<ul class="pdet__warnlist">
      <li>For external use only.</li>
      <li>Avoid direct contact with eyes.</li>
      <li>Discontinue use if irritation develops.</li>
      <li>Keep out of reach of children.</li>
    </ul>{%- endcapture -%}
    {%- capture pd_feeling -%}Rich, dense foam that rinses away completely — no film, no residue. Skin feels clean, balanced, and refreshed, never tight or stripped.{%- endcapture -%}
    {%- capture pd_benefits -%}<ul class="pdet__list">
      <li>Lifts away makeup, sunscreen, oil, and daily impurities completely</li>
      <li>Rinses clean with no film or residue left behind</li>
      <li>Prepares skin to receive everything that follows in the ritual</li>
      <li>Suitable for normal, combination, dry, oily, and sensitive skin</li>
    </ul>{%- endcapture -%}
    {%- capture pd_how_to_use -%}<ol class="pdet__list pdet__list--ol">
      <li>Dispense one to two pumps into damp hands.</li>
      <li>Massage gently over a damp face.</li>
      <li>Rinse thoroughly.</li>
      <li>Follow with, in the morning: Lumina, Cashmere, SPF. In the evening: Aura.</li>
    </ol>{%- endcapture -%}
  {%- when 'aura' -%}
    {%- assign pd_routine_am = 'Velvet (Cleanse) → Vitamin C Serum (coming soon) → Aura (Moisturize) → SPF (coming soon)' -%}
    {%- assign pd_routine_pm = 'Velvet (Cleanse) → Hydrating Serum (coming soon) → Aura (Moisturize) → Eye Cream (coming soon)' -%}
    {%- capture pd_warnings -%}<ul class="pdet__warnlist">
      <li>For external use only.</li>
      <li>Avoid direct contact with eyes.</li>
      <li>Discontinue use if irritation develops.</li>
      <li>Keep out of reach of children.</li>
      <li>Patch testing recommended before first use.</li>
    </ul>{%- endcapture -%}
    {%- capture pd_feeling -%}Silky, creamy, fast-absorbing. Naturally blue, straight from the peptide complex itself — not a dye, not a design choice. A soft, velvety finish with no fragrance and no residue.{%- endcapture -%}
    {%- capture pd_benefits -%}<ul class="pdet__list">
      <li>Deep hydration with a visibly smoother finish</li>
      <li>Pharmacist-selected peptide complex built on the ExoBlue™ base</li>
      <li>Fragrance-free and suitable for all skin types</li>
      <li>Silky finish that absorbs completely and never feels heavy</li>
    </ul>{%- endcapture -%}
    {%- capture pd_how_to_use -%}<ol class="pdet__list pdet__list--ol">
      <li>Warm a small amount between your fingertips.</li>
      <li>Press gently into skin — face and neck — until it disappears.</li>
      <li>Follow with sunscreen. Every morning, without exception.</li>
    </ol>{%- endcapture -%}
  {%- when 'cashmere' -%}
    {%- assign pd_routine_am = 'Velvet → Lumina → Cashmere → SPF' -%}
    {%- assign pd_routine_pm = 'Velvet → Aura (Cashmere may also be layered in the evening if additional hydration is desired.)' -%}
    {%- capture pd_warnings -%}<ul class="pdet__warnlist">
      <li>For external use only.</li>
      <li>Avoid direct contact with eyes.</li>
      <li>Discontinue use if irritation develops.</li>
      <li>Keep out of reach of children.</li>
    </ul>{%- endcapture -%}
    {%- capture pd_feeling -%}Lightweight lotion. Silky, fast-absorbing, with an elegant slip. Non-greasy and comfortable for all-day wear — soft, hydrated, smooth, never sticky.{%- endcapture -%}
    {%- capture pd_benefits -%}<ul class="pdet__list">
      <li>Provides lightweight daily hydration that absorbs quickly</li>
      <li>Layers beautifully under sunscreen and under makeup</li>
      <li>Leaves skin feeling soft and comfortable, never heavy</li>
      <li>Suitable for all skin types, for everyday use</li>
    </ul>{%- endcapture -%}
    {%- capture pd_how_to_use -%}<ol class="pdet__list pdet__list--ol">
      <li>Use morning and evening.</li>
      <li>Apply after serums.</li>
      <li>Massage gently into face and neck until absorbed.</li>
    </ol>{%- endcapture -%}
  {%- when 'silken' -%}
    {%- assign pd_routine_am = 'Velvet → Lumina → Cashmere → SPF (apply Silken to targeted areas after cleansing and before moisturizer)' -%}
    {%- assign pd_routine_pm = 'Velvet → Aura (apply Silken to targeted areas after cleansing and before moisturizer)' -%}
    {%- capture pd_warnings -%}<ul class="pdet__warnlist">
      <li>For external use only.</li>
      <li>Do not apply to open wounds or broken skin.</li>
      <li>Avoid direct contact with eyes.</li>
      <li>Discontinue use if irritation develops.</li>
      <li>Keep out of reach of children.</li>
    </ul>{%- endcapture -%}
    {%- capture pd_feeling -%}A silky, lightweight gel. Smooth to apply, non-greasy, designed to create a breathable protective layer that stays comfortable through a full day of wear.{%- endcapture -%}
    {%- capture pd_benefits -%}<ul class="pdet__list">
      <li>Helps improve the appearance of scars and uneven skin texture</li>
      <li>Leaves skin feeling smooth, comfortable, and lastingly hydrated</li>
      <li>Creates a breathable protective barrier suitable for daily use</li>
      <li>Suitable for all skin types, on fully healed scars</li>
    </ul>{%- endcapture -%}
    {%- capture pd_how_to_use -%}<ol class="pdet__list pdet__list--ol">
      <li>Apply a thin layer directly to clean, fully healed scars.</li>
      <li>Use morning and evening, as part of a consistent daily rhythm.</li>
      <li>Allow the product to dry completely before applying additional skincare or sunscreen.</li>
    </ol>{%- endcapture -%}
{%- endcase -%}

<section class="page-section mprod">
  <div class="page-section__inner">
    <div class="mprod__layout">

      {%- comment -%} ───── LEFT: gallery ───── {%- endcomment -%}
      <div class="mprod__gallery">
        <div class="mprod__main">
          {%- if product.featured_image -%}
            <img
              id="mprod-main-image"
              src="{{ product.featured_image | image_url: width: 1000 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="1000" height="1000">
          {%- else -%}
            <img src="{{ 'stock-product.jpg' | asset_url }}" alt="{{ product.title | escape }}" class="mprod__ph">
            {%- comment -%} Temporary Unsplash stock photo — replace with a real product image in Shopify admin {%- endcomment -%}
          {%- endif -%}
          {%- if product.images.size > 1 -%}
            <button type="button" class="mprod__nav mprod__nav--prev" aria-label="Previous image">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M15 6l-6 6 6 6"/></svg>
            </button>
            <button type="button" class="mprod__nav mprod__nav--next" aria-label="Next image">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="mprod__thumbs">
            {%- for image in product.images -%}
              <button
                type="button"
                class="mprod__thumb {% if forloop.first %}is-active{% endif %}"
                data-full="{{ image | image_url: width: 1000 }}"
                aria-label="View image {{ forloop.index }}">
                <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | escape }}" width="160" height="160" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ───── RIGHT: buy box ───── {%- endcomment -%}
      <div class="mprod__buy">
        {%- if product.type != blank -%}
          <span class="eyebrow mprod__eyebrow">{{ product.type }}</span>
        {%- endif -%}
        <h1 class="display-h mprod__title">{{ product.title }}</h1>

        {%- if benefit != blank -%}
          <p class="mprod__benefit">{{ benefit }}</p>
        {%- endif -%}

        <div class="mprod__price">
          <span class="mprod__price-now">{{ cv.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <s class="mprod__price-was">{{ product.compare_at_price | money }}</s>
          {%- endif -%}
        </div>

        {%- form 'product', product, id: 'mprod-form', class: 'mprod__form' -%}
          <div class="mprod__row mprod__row--options">
            {%- if product.variants.size > 1 -%}
              <div class="mprod__variants">
                <label for="mprod-variant" class="mprod__field-label">Option</label>
                <select id="mprod-variant" name="id" class="mprod__select">
                  {%- for variant in product.variants -%}
                    <option
                      value="{{ variant.id }}"
                      {% if variant == cv %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}>
                      {{ variant.title }} — {{ variant.price | money }}{% unless variant.available %} (Sold out){% endunless %}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- else -%}
              <input type="hidden" name="id" value="{{ cv.id }}">
            {%- endif -%}

            <div class="mprod__qty">
              <label for="mprod-quantity" class="mprod__field-label">Quantity</label>
              <input type="number" id="mprod-quantity" name="quantity" value="1" min="1" class="mprod__qty-input">
            </div>
          </div>

          <div class="mprod__row mprod__row--actions">
            {%- if product.available -%}
              <button type="submit" name="add" class="btn btn--primary mprod__add">Add to Bag</button>
            {%- else -%}
              <button type="submit" name="add" class="btn btn--primary mprod__add" disabled>Sold Out</button>
            {%- endif -%}

            <button class="wish-btn mprod__wish" type="button" data-wishlist-toggle data-handle="{{ product.handle }}" data-title="{{ product.title | escape }}" data-price="{{ cv.price | money }}" data-image="{{ product.featured_image | image_url: width: 200 }}" data-url="{{ product.url }}" aria-label="Save to wishlist">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 20s-7-4.6-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.4 12 20 12 20Z"/></svg>
              <span>Save to wishlist</span>
            </button>
          </div>
        {%- endform -%}

        <ul class="mprod__trust">
          <li>Pharmacist-formulated</li>
          <li>Hand-numbered</li>
          <li>Made in Houston</li>
        </ul>

        {%- comment -%} Routine/Story/Warnings show only if there's content; Feeling/Benefits/How-to-Use always have a fallback, so the accordion always renders {%- endcomment -%}
          <div class="mprod__info-accordion">
            {%- if pd_routine_am != blank or pd_routine_pm != blank -%}
              <div class="mprod__acc-item">
                <button type="button" class="mprod__acc-q" aria-expanded="false" aria-controls="mprod-acc-routine">
                  <span class="mprod__acc-label">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 3v4M12 17v4M4.2 7l3.5 2M16.3 15l3.5 2M4.2 17l3.5-2M16.3 9l3.5-2"/><circle cx="12" cy="12" r="3.2"/></svg>
                    Routine Placement
                  </span>
                  <span class="mprod__acc-icon" aria-hidden="true">+</span>
                </button>
                <div class="mprod__acc-a" id="mprod-acc-routine">
                  <div class="mprod__acc-a-inner">
                    {%- if pd_routine_am != blank -%}
                      <p><strong>Morning —</strong> {{ pd_routine_am }}</p>
                    {%- endif -%}
                    {%- if pd_routine_pm != blank -%}
                      <p><strong>Evening —</strong> {{ pd_routine_pm }}</p>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endif -%}

            {%- if product.description != blank -%}
              <div class="mprod__acc-item">
                <button type="button" class="mprod__acc-q" aria-expanded="false" aria-controls="mprod-acc-story">
                  <span class="mprod__acc-label">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 4h9l3 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z"/><path d="M9 10h6M9 14h6M9 18h3"/></svg>
                    The Full Story
                  </span>
                  <span class="mprod__acc-icon" aria-hidden="true">+</span>
                </button>
                <div class="mprod__acc-a" id="mprod-acc-story">
                  <div class="rte mprod__acc-a-inner">{{ product.description }}</div>
                </div>
              </div>
            {%- endif -%}

            {%- if pd_warnings != blank -%}
              <div class="mprod__acc-item">
                <button type="button" class="mprod__acc-q" aria-expanded="false" aria-controls="mprod-acc-warnings">
                  <span class="mprod__acc-label">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 3 2 21h20L12 3Z"/><path d="M12 10v4"/><circle cx="12" cy="17" r=".6" fill="currentColor" stroke="none"/></svg>
                    Warnings
                  </span>
                  <span class="mprod__acc-icon" aria-hidden="true">+</span>
                </button>
                <div class="mprod__acc-a" id="mprod-acc-warnings">
                  <div class="mprod__acc-a-inner">{{ pd_warnings }}</div>
                </div>
              </div>
            {%- endif -%}

            <div class="mprod__acc-item">
              <button type="button" class="mprod__acc-q" aria-expanded="false" aria-controls="mprod-acc-feeling">
                <span class="mprod__acc-label">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 21s-7-4.35-7-10.5A4.5 4.5 0 0 1 12 6a4.5 4.5 0 0 1 7 4.5C19 16.65 12 21 12 21Z"/></svg>
                  The Feeling
                </span>
                <span class="mprod__acc-icon" aria-hidden="true">+</span>
              </button>
              <div class="mprod__acc-a" id="mprod-acc-feeling">
                <div class="mprod__acc-a-inner">
                  <p>
                    {%- if mf.feeling != blank -%}
                      {{ mf.feeling }}
                    {%- elsif pd_feeling != blank -%}
                      {{ pd_feeling }}
                    {%- else -%}
                      A quiet ritual of care. {{ product.title }} is compounded by hand in small batches so every application feels deliberate, clean, and calm — never rushed, never generic.
                    {%- endif -%}
                  </p>
                </div>
              </div>
            </div>

            <div class="mprod__acc-item">
              <button type="button" class="mprod__acc-q" aria-expanded="false" aria-controls="mprod-acc-benefits">
                <span class="mprod__acc-label">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 12.5 11 15l4.5-5.5"/><circle cx="12" cy="12" r="9"/></svg>
                  Key Benefits
                </span>
                <span class="mprod__acc-icon" aria-hidden="true">+</span>
              </button>
              <div class="mprod__acc-a" id="mprod-acc-benefits">
                <div class="mprod__acc-a-inner">
                  {%- if mf.benefits != blank -%}
                    <div class="rte">{{ mf.benefits }}</div>
                  {%- elsif pd_benefits != blank -%}
                    {{ pd_benefits }}
                  {%- else -%}
                    <ul class="pdet__list">
                      <li>Built around a single clinical-grade active — no filler blends.</li>
                      <li>Compounded by hand in Houston, hand-numbered in batches of 200.</li>
                      <li>Pharmacist-formulated for real, visible skin results.</li>
                      <li>Gentle enough for daily use in your complete ritual.</li>
                    </ul>
                  {%- endif -%}
                </div>
              </div>
            </div>

            <div class="mprod__acc-item">
              <button type="button" class="mprod__acc-q" aria-expanded="false" aria-controls="mprod-acc-how-to-use">
                <span class="mprod__acc-label">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>
                  How to Use
                </span>
                <span class="mprod__acc-icon" aria-hidden="true">+</span>
              </button>
              <div class="mprod__acc-a" id="mprod-acc-how-to-use">
                <div class="mprod__acc-a-inner">
                  {%- if mf.how_to_use != blank -%}
                    <div class="rte">{{ mf.how_to_use }}</div>
                  {%- elsif pd_how_to_use != blank -%}
                    {{ pd_how_to_use }}
                  {%- else -%}
                    <p>Apply a small amount to clean skin, morning and evening. Follow with your next ritual step. Introduce gradually if your skin is new to active formulas.</p>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
/* .page-section's generic padding shorthand (up to 160px top) was winning over this section's
   own intended top spacing due to equal specificity + later file load order — pin it down with
   a compound selector so it always wins regardless of stylesheet order. */
.page-section.mprod { padding-top: clamp(20px, 3vw, 40px); }
.mprod__layout { display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(32px, 5vw, 80px); align-items: start; }
.mprod__main { position: relative; border-radius: 16px; overflow: hidden; background: var(--grad-cream); aspect-ratio: 1/1; }
.mprod__main img, .mprod__ph { width: 100%; height: 100%; object-fit: cover; display: block; }
.mprod__nav {
  position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
  width: 40px; height: 40px; border-radius: 50%; border: 0;
  background: rgba(249,244,237,.9); color: var(--c-forest);
  display: grid; place-items: center; cursor: pointer;
  opacity: 0; transition: opacity .3s var(--ease-out), background .3s var(--ease-out);
  backdrop-filter: blur(6px);
}
.mprod__main:hover .mprod__nav { opacity: 1; }
.mprod__nav:hover { background: var(--c-cream); }
.mprod__nav--prev { left: 14px; }
.mprod__nav--next { right: 14px; }
@media (hover: none) { .mprod__nav { opacity: 1; } }

.mprod__thumbs { display: flex; gap: 12px; margin-top: 14px; flex-wrap: wrap; }
.mprod__thumb {
  width: 76px; height: 76px; border-radius: 10px; overflow: hidden;
  border: 1px solid var(--c-line-soft); cursor: pointer; padding: 0; background: none;
  transition: border-color .3s;
}
.mprod__thumb.is-active { border-color: var(--c-forest); }
.mprod__thumb img { width: 100%; height: 100%; object-fit: cover; }

.mprod__buy { position: sticky; top: 100px; }
.mprod__eyebrow { display: inline-block; margin-bottom: 14px; color: var(--c-tan); }
.mprod__title { margin: 0 0 16px; }
.mprod__benefit { font-family: var(--ff-display); font-size: 20px; font-style: italic; color: var(--c-ink-soft); margin: 0 0 22px; max-width: 40ch; }
.mprod__price { display: flex; align-items: baseline; gap: 12px; margin-bottom: 28px; }
.mprod__price-now { font-size: 24px; color: var(--c-forest); font-weight: 500; }
.mprod__price-was { font-size: 17px; color: var(--c-ink-mute); }

.mprod__form { display: flex; flex-direction: column; gap: 18px; }
.mprod__field-label { display: block; font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--c-ink-mute); margin-bottom: 8px; }
.mprod__select, .mprod__qty-input {
  padding: 12px 14px; border: 1px solid var(--c-line-soft); border-radius: 8px;
  background: var(--c-cream); font-size: 15px; color: var(--c-forest); font-family: var(--ff-body);
}
.mprod__select { width: 100%; appearance: none; }
.mprod__qty-input { width: 100%; }

.mprod__row { display: flex; gap: 16px; }
.mprod__row--options { align-items: flex-end; }
.mprod__row--options .mprod__variants { flex: 1 1 auto; min-width: 0; }
.mprod__row--options .mprod__qty { flex: 0 0 130px; }
.mprod__row--options input[type="hidden"] ~ .mprod__qty { flex: 1 1 auto; }

.mprod__row--actions { align-items: stretch; }
.mprod__row--actions .mprod__add { flex: 1 1 auto; width: auto; margin: 0; }
.mprod__add[disabled] { opacity: .5; cursor: default; }
.mprod__row--actions .mprod__wish { margin-top: 0; flex: 0 0 auto; }

@media (max-width: 480px) {
  .mprod__row--options, .mprod__row--actions { flex-direction: column; align-items: stretch; }
  .mprod__row--options .mprod__qty { flex: 1 1 auto; }
  .mprod__row--actions .mprod__wish { justify-content: center; }
}

.mprod__trust {
  list-style: none; margin: 26px 0 0; padding: 22px 0 0; border-top: 1px solid var(--c-line-soft);
  display: flex; flex-wrap: wrap; gap: 8px 20px;
  font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--c-ink-mute);
}
.mprod__trust li { position: relative; padding-left: 18px; }
.mprod__trust li::before { content: '·'; position: absolute; left: 4px; color: var(--c-tan); font-size: 18px; line-height: .9; }

@media (max-width: 860px) {
  .mprod__layout { grid-template-columns: 1fr; }
  .mprod__buy { position: static; }
}

/* Left-column accordion: Routine Placement / The Full Story / Warnings */
.mprod__info-accordion { margin-top: clamp(28px, 3vw, 44px); border-top: 1px solid var(--c-line-soft); }
.mprod__acc-item { border-bottom: 1px solid var(--c-line-soft); }
.mprod__acc-q {
  width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px;
  padding: 18px 2px; background: none; border: 0; cursor: pointer;
  font-family: var(--ff-body); font-size: 12.5px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  color: var(--c-forest); transition: color .3s var(--ease-out);
}
.mprod__acc-q:hover { color: var(--c-tan-2); }
.mprod__acc-label { display: flex; align-items: center; gap: 12px; }
.mprod__acc-label svg { flex: 0 0 auto; color: var(--c-tan-2); }
.mprod__acc-icon { flex: 0 0 auto; font-size: 18px; line-height: 1; color: var(--c-ink-mute); transition: transform .3s var(--ease-out); }
.mprod__acc-q[aria-expanded="true"] .mprod__acc-icon { transform: rotate(45deg); }
.mprod__acc-a { max-height: 0; overflow: hidden; transition: max-height .35s var(--ease-out); }
.mprod__acc-a.is-open { max-height: 600px; }
.mprod__acc-a-inner { padding: 0 2px 20px; font-size: 14px; line-height: 1.7; color: var(--c-ink-soft); }
.mprod__acc-a-inner p { margin: 0 0 10px; }
.mprod__acc-a-inner p:last-child { margin-bottom: 0; }
.mprod__acc-a-inner strong { color: var(--c-forest); font-weight: 600; }
{% endstylesheet %}

{% javascript %}
(function () {
  var main = document.getElementById('mprod-main-image');
  var thumbs = document.querySelectorAll('.mprod__thumb');

  function activate(index) {
    var t = thumbs[index];
    if (!t) return;
    var full = t.getAttribute('data-full');
    if (main && full) main.src = full;
    thumbs.forEach(function (x) { x.classList.remove('is-active'); });
    t.classList.add('is-active');
  }

  thumbs.forEach(function (t, i) {
    t.addEventListener('click', function () { activate(i); });
  });

  // Prev/next arrows on the main image, shown on hover — cycle through the same thumbnail list
  var prevBtn = document.querySelector('.mprod__nav--prev');
  var nextBtn = document.querySelector('.mprod__nav--next');
  function currentIndex() {
    var found = 0;
    thumbs.forEach(function (t, i) { if (t.classList.contains('is-active')) found = i; });
    return found;
  }
  if (prevBtn) prevBtn.addEventListener('click', function () {
    activate((currentIndex() - 1 + thumbs.length) % thumbs.length);
  });
  if (nextBtn) nextBtn.addEventListener('click', function () {
    activate((currentIndex() + 1) % thumbs.length);
  });

  // Keep hidden/select variant id in sync with price display (single-select variant case)
  var select = document.getElementById('mprod-variant');
  if (select) {
    select.addEventListener('change', function () {
      var opt = select.options[select.selectedIndex];
      var priceEl = document.querySelector('.mprod__price-now');
      var match = opt.textContent.match(/—\s*(.+?)(?:\s*\(|$)/);
      if (priceEl && match) priceEl.textContent = match[1].trim();
    });
  }

  // Left-column accordion (Routine Placement / The Full Story / Warnings)
  document.querySelectorAll('.mprod__acc-q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      var panel = document.getElementById(btn.getAttribute('aria-controls'));
      if (panel) panel.classList.toggle('is-open', !open);
    });
  });
})();
{% endjavascript %}

