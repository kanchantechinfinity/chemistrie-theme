<!-- ───── Footer ───── -->
<footer class="footer">
  <div class="footer__top footer__top--5col">
    <div class="footer__brand">
      <span class="footer__wordmark">CHEMISTRIE</span>
      <p class="footer__tag">Made by pharmacists.<br/>Made for the women they love.</p>
      <div class="footer__seal">
        <span>Rx</span>
        <em>Pharmacist-formulated · Houston, TX</em>
      </div>
    </div>

    <nav class="footer__col">
      <h4>The Collection</h4>
      <a href="{{ routes.all_products_collection_url }}">All Products</a>
      <a href="/pages/the-ritual">The Ritual Set</a>
      
    </nav>

    <nav class="footer__col">
      <h4>The Brand</h4>
      <a href="/pages/our-story">Our Story</a>
      <a href="/pages/the-pharmacists">The Pharmacists</a>
      <a href="/pages/the-ritual">The Ritual</a>
      <a href="/pages/home">The Active Index</a>
    </nav>

    {%- liquid
      assign journal_url_f = blogs.journal.url
      if journal_url_f == blank
        for b in blogs
          assign journal_url_f = b[1].url
          break
        endfor
      endif
      if journal_url_f == blank
        assign journal_url_f = '/blogs/journal'
      endif
    -%}
    <nav class="footer__col">
      <h4>The Journal</h4>
      <a href="{{ journal_url_f }}">Blog</a>
    </nav>

    <nav class="footer__col">
      <h4>Help</h4>
      <a href="/pages/faq">FAQ</a>
      <a href="/pages/shipping-returns">Shipping &amp; Returns</a>
      <a href="/pages/contact">Contact</a>
      <a href="/pages/accessibility">Accessibility</a>
    </nav>

    {%- liquid
      assign ig = settings.social_instagram | default: section.settings.instagram | default: '#'
      assign tt = settings.social_tiktok | default: section.settings.tiktok | default: '#'
      assign pin = settings.social_pinterest | default: section.settings.pinterest | default: '#'
      assign mail = settings.social_email | default: section.settings.email | default: 'hello@chemistrie.com'
    -%}
    <nav class="footer__col">
      <h4>Connect</h4>
      <a href="{{ ig }}">Instagram</a>
      <a href="{{ tt }}">TikTok</a>
      <a href="{{ pin }}">Pinterest</a>
      <a href="mailto:{{ mail }}">Email</a>
    </nav>
  </div>

  <div class="footer__bot">
    <span>© Chemistrie LLC, {{ 'now' | date: '%Y' }}. Compounded with care in Houston.</span>
    <div class="footer__legal">
      <a href="/pages/terms">Terms</a>
      <a href="/pages/privacy">Privacy</a>
      <a href="/pages/accessibility">Accessibility</a>
    </div>
    <div class="footer__social">
      <a href="{{ ig }}" aria-label="Instagram">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg>
      </a>
      <a href="{{ pin }}" aria-label="Pinterest">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M11 22 13 13M9 9c0-2 1.5-4 4-4s4 2 4 4-1 5-4 5c-1.2 0-2-1-2-2"/></svg>
      </a>
      <a href="{{ tt }}" aria-label="TikTok">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M14 4v10a4 4 0 1 1-4-4M14 4c0 3 2 5 5 5"/></svg>
      </a>
    </div>
  </div>

  <div class="footer__wordmark-huge" aria-hidden="true">CHEMISTRIE</div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "pinterest", "label": "Pinterest URL" },
    { "type": "text", "id": "email", "label": "Contact email", "default": "hello@chemistrie.com" }
  ]
}
{% endschema %}
