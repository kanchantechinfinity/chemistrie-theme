{%- assign shown = 0 -%}
<section class="rel page-section page-section--paper">
  <div class="page-section__inner">
    <div class="rel__head">
      <span class="eyebrow">— Related reading —</span>
      <h2 class="display-h rel__title">More from <em>the bench.</em></h2>
    </div>
    <div class="rel__grid">
      {%- for a in blog.articles -%}
        {%- if a.id != article.id and shown < 3 -%}
          {%- assign shown = shown | plus: 1 -%}
          {%- assign words = a.content | strip_html | split: ' ' | size -%}
          {%- assign rt = words | divided_by: 200 | at_least: 1 -%}
          <article class="rcard">
            <a class="rcard__media" href="{{ a.url }}" aria-label="{{ a.title | escape }}">
              {%- if a.image -%}
                {{ a.image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '350,700', alt: a.image.alt | default: a.title, class: 'rcard__img' }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'rcard__img' }}
              {%- endif -%}
              {%- if a.tags.size > 0 -%}<span class="rcard__cat">{{ a.tags.first }}</span>{%- endif -%}
            </a>
            <a class="rcard__title" href="{{ a.url }}">{{ a.title }}</a>
            <div class="rcard__meta">
              <span>{{ a.published_at | date: '%b %-d, %Y' }}</span>
              <span aria-hidden="true">·</span>
              <span>{{ rt }} min read</span>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if shown == 0 -%}
      <p class="rel__empty"><a href="{{ blog.url }}" class="btn btn--ghost btn--dark">Browse the Journal</a></p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.rel__head { text-align: center; margin-bottom: clamp(40px, 6vw, 64px); }
.rel__title { margin-top: 12px; }
.rel__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(24px, 3vw, 44px); }
.rcard { display: flex; flex-direction: column; gap: 12px; }
.rcard__media { display: block; position: relative; aspect-ratio: 4 / 3; border-radius: 12px; overflow: hidden; background: var(--grad-cream); }
.rcard__img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s var(--ease-out); }
.rcard__media:hover .rcard__img { transform: scale(1.05); }
.rcard__cat { position: absolute; top: 12px; left: 12px; font-size: 10px; letter-spacing: .16em; text-transform: uppercase; background: var(--c-cream); color: var(--c-forest); padding: 5px 11px; border-radius: 999px; }
.rcard__title { font-family: var(--ff-display); font-size: clamp(20px, 2vw, 24px); line-height: 1.15; color: var(--c-forest); transition: color .3s; }
.rcard__title:hover { color: var(--c-tan-2); }
.rcard__meta { display: flex; gap: 8px; font-size: 12px; color: var(--c-ink-mute); }
.rel__empty { text-align: center; }
@media (max-width: 900px) { .rel__grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .rel__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Related Articles",
  "settings": [],
  "presets": [{ "name": "Related Articles" }]
}
{% endschema %}
