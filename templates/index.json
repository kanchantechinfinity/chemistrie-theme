    "founders_cch8nz": {
      "type": "founders",
      "name": "Founders",
      "settings": {
        "caption": "The founding pharmacists, photographed in the compounding lab — Houston, 2026.",
        "heading": "Two compounding<br>pharmacists.<br><em>One promise.</em>",
        "founder1_name": "Dr. A —",
        "founder2_name": "Dr. M —",
        "founder3_name": "Dr. S —",
        "lede": "They met behind the same bench in Houston, weighing actives by the milligram for women who had been failed by everything on the shelf.",
        "paragraph1": "Wives wanted retinol that didn't burn. Mothers wanted vitamin C that didn't oxidise in a week. Best friends wanted a moisturiser they could hand down. So they started making it — quietly, by hand, in concentrations the industry deemed too expensive to mass-produce.",
        "paragraph2": "Chemistrie is what happened when their patient list became a waiting list.",
        "sig": "— Dr. A & Dr. M",
        "sig_sub": "Compounding Pharmacists · Founders"
      }
    },
